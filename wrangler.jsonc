{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "the-churfer-website",
  "compatibility_date": "2026-04-23",
  "compatibility_flags": ["nodejs_compat"],
  "images": {
    "binding": "IMAGES"
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "REPLACE_WITH_SESSION_KV_NAMESPACE_ID"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "the-churfer-emdash",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "the-churfer-media"
    }
  ]
}
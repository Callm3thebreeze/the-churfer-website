---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { PortableText } from "emdash/ui";
import YouTubeEmbed from "../../components/YouTubeEmbed.astro";
import { buildVideoSchema } from "../../lib/seo";
import {
  formatDateLong,
  getCategoryLabel,
  getVideoEmbedUrl,
  getVideoEntryBySlug,
  getVideoOgImage,
} from "../../lib/videos";

const slug = Astro.params.slug ?? "";
const video = slug ? await getVideoEntryBySlug(slug) : null;

if (!video) {
  Astro.response.status = 404;
}

const paragraphs = video?.contentText.split("\n\n").filter(Boolean) ?? [];
const videoSchema = video
  ? buildVideoSchema({
      title: video.title,
      description: video.description,
      canonicalUrl: new URL(
        `/video/${video.slug}`,
        import.meta.env.SITE ?? "https://thechurfer.com",
      ).toString(),
      imageUrl: getVideoOgImage(video),
      uploadDate: video.date,
      embedUrl: getVideoEmbedUrl(video),
    })
  : undefined;
---

<BaseLayout
  title={video?.title ?? "Proyecto no encontrado"}
  description={video?.description ??
    "La entrada de video solicitada no existe o aun no esta publicada."}
  ogType={video ? "video.other" : undefined}
  ogImage={video ? getVideoOgImage(video) : undefined}
  schema={videoSchema}
>
  {
    video ? (
      <article class="video-detail">
        <section class="video-detail__hero">
          <div class="video-detail__embed container-narrow">
            {video.youtubeId ? (
              <YouTubeEmbed videoId={video.youtubeId} title={video.title} />
            ) : (
              <a
                href={video.videoUrl}
                class="video-detail__video-link"
                target="_blank"
                rel="noreferrer"
              >
                <span class="label">Video externo</span>
                <strong>{video.title}</strong>
                <span>Abrir video</span>
              </a>
            )}
          </div>
        </section>

        <section class="video-detail__content container-narrow">
          <div class="video-detail__meta reveal">
            {getCategoryLabel(video.category) && (
              <span class="label">{getCategoryLabel(video.category)}</span>
            )}
            {video.date && (
              <time datetime={video.date}>{formatDateLong(video.date)}</time>
            )}
          </div>

          <h1 class="reveal">{video.title}</h1>

          <div class="video-detail__body reveal">
            {video.contentBlocks ? (
              <PortableText value={video.contentBlocks} />
            ) : (
              paragraphs.map((p) => <p>{p}</p>)
            )}
          </div>

          <a href="/video" class="back-link reveal">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M19 12H5M12 5l-7 7 7 7" />
            </svg>
            Volver a vídeos
          </a>
        </section>
      </article>
    ) : (
      <section class="video-detail__content container-narrow video-detail__empty">
        <span class="label">404</span>
        <h1>Proyecto no encontrado</h1>
        <p>
          La entrada de video que buscas no existe o todavia no esta publicada.
        </p>
        <a href="/video" class="back-link">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="M19 12H5M12 5l-7 7 7 7" />
          </svg>
          Volver a vídeos
        </a>
      </section>
    )
  }
</BaseLayout>

<style>
  .video-detail__hero {
    padding-top: calc(80px + var(--space-lg));
    padding-bottom: var(--space-lg);
    background: var(--color-black);
  }

  .container-narrow {
    max-width: 900px;
    margin-inline: auto;
    padding-inline: var(--space-md);
  }

  .video-detail__video-link {
    min-height: clamp(260px, 48vw, 520px);
    display: grid;
    align-content: center;
    justify-items: start;
    gap: var(--space-xs);
    padding: clamp(1.5rem, 3vw, 2.6rem);
    text-decoration: none;
    color: var(--color-text);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      radial-gradient(
        circle at top right,
        rgba(212, 168, 83, 0.22),
        transparent 36%
      ),
      linear-gradient(
        145deg,
        rgba(255, 255, 255, 0.04),
        rgba(255, 255, 255, 0.015)
      );
  }

  .video-detail__video-link strong {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    line-height: 1.05;
  }

  .video-detail__video-link span:last-child {
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-sunset);
    font-size: var(--text-xs);
  }

  /* ═══ CONTENT ═══ */
  .video-detail__content {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-section);
  }

  .video-detail__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .video-detail__meta time {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    font-style: italic;
    font-family: var(--font-display);
  }

  .video-detail__content h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.15;
    margin-bottom: var(--space-lg);
  }

  .video-detail__body {
    max-width: 65ch;
  }

  .video-detail__body :global(p) {
    font-size: var(--text-base);
    line-height: 1.85;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .video-detail__body :global(p:last-child) {
    margin-bottom: 0;
  }

  .video-detail__body :global(h2),
  .video-detail__body :global(h3) {
    font-family: var(--font-display);
    line-height: 1.1;
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .video-detail__body :global(ul),
  .video-detail__body :global(ol) {
    color: var(--color-text-muted);
    padding-left: 1.2em;
    margin-bottom: var(--space-md);
  }

  .video-detail__body :global(a) {
    color: var(--color-sunset);
  }

  .video-detail__empty {
    min-height: calc(100vh - 160px);
    display: grid;
    align-content: center;
    gap: var(--space-sm);
  }

  .video-detail__empty p {
    max-width: 42ch;
    color: var(--color-text-muted);
  }

  /* ═══ BACK LINK ═══ */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    margin-top: var(--space-xl);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .back-link:hover {
    color: var(--color-sunset);
  }

  .back-link svg {
    transition: transform var(--duration-fast) var(--ease-out-quart);
  }

  .back-link:hover svg {
    transform: translateX(-4px);
  }
</style>

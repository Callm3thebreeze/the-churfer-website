---
import BaseLayout from "../../layouts/BaseLayout.astro";
import YouTubeEmbed from "../../components/YouTubeEmbed.astro";
import {
  videos,
  formatDateLong,
  getCategoryLabel,
  type Video,
} from "../../data/videos";

export function getStaticPaths() {
  return videos.map((video) => ({
    params: { slug: video.slug },
    props: { video },
  }));
}

interface Props {
  video: Video;
}

const { video } = Astro.props;
const paragraphs = video.body.split("\n\n").filter(Boolean);
---

<BaseLayout title={video.title} description={video.description}>
  <article class="video-detail">
    <!-- ═══ HERO / EMBED ═══ -->
    <section class="video-detail__hero">
      <div class="video-detail__embed container-narrow">
        <YouTubeEmbed videoId={video.youtubeId} title={video.title} />
      </div>
    </section>

    <!-- ═══ CONTENT ═══ -->
    <section class="video-detail__content container-narrow">
      <div class="video-detail__meta reveal">
        <span class="label">{getCategoryLabel(video.category)}</span>
        <time datetime={video.date}>{formatDateLong(video.date)}</time>
      </div>

      <h1 class="reveal">{video.title}</h1>

      <div class="video-detail__body reveal">
        {paragraphs.map((p) => <p>{p}</p>)}
      </div>

      <a href="/video" class="back-link reveal">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path d="M19 12H5M12 5l-7 7 7 7"></path>
        </svg>
        Volver a vídeos
      </a>
    </section>
  </article>
</BaseLayout>

<style>
  .video-detail__hero {
    padding-top: calc(80px + var(--space-lg));
    padding-bottom: var(--space-lg);
    background: var(--color-black);
  }

  .container-narrow {
    max-width: 900px;
    margin-inline: auto;
    padding-inline: var(--space-md);
  }

  /* ═══ CONTENT ═══ */
  .video-detail__content {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-section);
  }

  .video-detail__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .video-detail__meta time {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    font-style: italic;
    font-family: var(--font-display);
  }

  .video-detail__content h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.15;
    margin-bottom: var(--space-lg);
  }

  .video-detail__body {
    max-width: 65ch;
  }

  .video-detail__body p {
    font-size: var(--text-base);
    line-height: 1.85;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .video-detail__body p:last-child {
    margin-bottom: 0;
  }

  /* ═══ BACK LINK ═══ */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    margin-top: var(--space-xl);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .back-link:hover {
    color: var(--color-sunset);
  }

  .back-link svg {
    transition: transform var(--duration-fast) var(--ease-out-quart);
  }

  .back-link:hover svg {
    transform: translateX(-4px);
  }
</style>

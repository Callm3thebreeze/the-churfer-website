---
import BaseLayout from "../../layouts/BaseLayout.astro";
import YouTubeEmbed from "../../components/YouTubeEmbed.astro";
import { getVideoLibrary } from "../../lib/videos";

const { videos, categories } = await getVideoLibrary();
const totalLabel = videos.length.toString().padStart(2, "0");
---

<BaseLayout
  title="Vídeo"
  description="Producciones audiovisuales de Sergi Ortega — The Churfer. Vídeo comercial para marcas, videoclips musicales y cobertura de eventos deportivos."
>
  <!-- ═══ HERO ═══ -->
  <section class="page-hero vhero">
    <div class="vhero__inner container">
      <div class="vhero__text">
        <h1 class="vhero__title reveal">Vídeo</h1>
        <p class="vhero__desc reveal">
          Vídeo comercial para empresas, videoclips musicales y cobertura de
          eventos deportivos. Grabación y edición con un enfoque
          cinematográfico.
        </p>
      </div>
      <div class="vhero__counter reveal">
        <span class="vhero__counter-num">{totalLabel}</span>
        <span class="vhero__counter-label">producciones</span>
      </div>
    </div>
    <div class="vhero__line"></div>
  </section>

  <!-- ═══ HORIZONTAL SCROLL GALLERY ═══ -->
  <section class="hscroll" id="hscroll" aria-label="Lista de producciones">
    <div class="hscroll__sticky">
      <nav class="hscroll__nav container" aria-label="Filtrar por tipo">
        {
          categories.map(({ id, label }) => (
            <button
              class="vfilters__btn pill-btn"
              data-filter={id}
              aria-pressed={id === "all" ? "true" : "false"}
            >
              {label}
            </button>
          ))
        }
      </nav>

      <div class="hscroll__track" id="hscroll-track">
        {
          videos.map((video, i) => (
            <article class="vcard" data-category={video.category}>
              <div class="vcard__inner">
                <div class="vcard__embed">
                  {video.youtubeId ? (
                    <YouTubeEmbed
                      videoId={video.youtubeId}
                      title={video.title}
                    />
                  ) : (
                    <a
                      href={video.videoUrl}
                      class="vcard__embed-fallback"
                      target="_blank"
                      rel="noreferrer"
                    >
                      <span class="label">Video externo</span>
                      <strong>{video.title}</strong>
                      <span>Abrir video</span>
                    </a>
                  )}
                </div>
                <div class="vcard__footer">
                  <span class="vcard__num">
                    {(i + 1).toString().padStart(2, "0")}
                  </span>
                  <h2 class="vcard__title">{video.title}</h2>
                  <a href={`/video/${video.slug}`} class="vcard__link">
                    Ver proyecto
                    <svg
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                    >
                      <path d="M5 12h14M12 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <div class="hscroll__bar">
        <div class="hscroll__bar-fill" id="hscroll-bar"></div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const section = document.getElementById("hscroll")!;
  const track = document.getElementById("hscroll-track")!;
  const bar = document.getElementById("hscroll-bar")!;
  const filterBtns =
    document.querySelectorAll<HTMLButtonElement>(".vfilters__btn");
  const allCards = track.querySelectorAll<HTMLElement>(".vcard");

  const DESKTOP_MIN = 769;

  function isDesktop(): boolean {
    return window.innerWidth >= DESKTOP_MIN;
  }

  function getVisibleCards(): HTMLElement[] {
    return Array.from(allCards).filter(
      (c) => !c.classList.contains("is-hidden"),
    );
  }

  // ── Lerp state ──
  let currentX = 0;
  let targetX = 0;
  let currentBar = 0;
  let targetBar = 0;
  const LERP_SPEED = 0.08; // lower = smoother (0.05–0.12 sweet spot)
  const SCALE_MIN = 0.85;
  const SCALE_MAX = 1;

  // Cache inner elements for scale
  const cardInners = Array.from(allCards).map(
    (c) => c.querySelector<HTMLElement>(".vcard__inner")!,
  );

  function lerp(a: number, b: number, t: number): number {
    return a + (b - a) * t;
  }

  // Ease-in-out: smooths entry/exit of horizontal zone
  function easeInOutCubic(t: number): number {
    return t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 1) / 2;
  }

  function updateDimensions(): void {
    const visible = getVisibleCards();
    if (isDesktop() && visible.length > 1) {
      // Extra 0.5 screen at start + end for breathing room
      section.style.height = `${(visible.length + 1) * 100}vh`;
    } else {
      section.style.height = "";
      track.style.transform = "";
    }
  }

  function computeTargets(): void {
    if (!isDesktop()) {
      targetX = 0;
      targetBar = 0;
      return;
    }

    const visible = getVisibleCards();
    if (visible.length <= 1) {
      targetX = 0;
      targetBar = 100;
      return;
    }

    const rect = section.getBoundingClientRect();
    const scrollRange = section.offsetHeight - window.innerHeight;
    if (scrollRange <= 0) return;

    const rawProgress = Math.max(0, Math.min(1, -rect.top / scrollRange));
    const easedProgress = easeInOutCubic(rawProgress);
    const maxTranslate = (visible.length - 1) * window.innerWidth;

    targetX = -easedProgress * maxTranslate;
    targetBar = rawProgress * 100;
  }

  // ── rAF loop ──
  function animate(): void {
    currentX = lerp(currentX, targetX, LERP_SPEED);
    currentBar = lerp(currentBar, targetBar, LERP_SPEED);

    // Snap when close enough to avoid infinite micro-updates
    if (Math.abs(currentX - targetX) < 0.5) currentX = targetX;
    if (Math.abs(currentBar - targetBar) < 0.1) currentBar = targetBar;

    track.style.transform = `translateX(${currentX}px)`;
    bar.style.width = `${currentBar}%`;

    // ── Per-card scale based on distance to viewport center ──
    if (isDesktop()) {
      const vpCenter = window.innerWidth / 2;
      allCards.forEach((card, i) => {
        if (card.classList.contains("is-hidden")) return;
        const rect = card.getBoundingClientRect();
        const cardCenter = rect.left + rect.width / 2;
        // 0 = perfectly centered, 1 = one full viewport width away
        const dist = Math.min(
          1,
          Math.abs(cardCenter - vpCenter) / window.innerWidth,
        );
        // Smooth falloff
        const scale = SCALE_MAX - (SCALE_MAX - SCALE_MIN) * dist * dist;
        cardInners[i].style.transform = `scale(${scale})`;
        cardInners[i].style.opacity = `${0.4 + 0.6 * (1 - dist)}`;
      });
    } else {
      cardInners.forEach((inner) => {
        inner.style.transform = "";
        inner.style.opacity = "";
      });
    }

    requestAnimationFrame(animate);
  }

  requestAnimationFrame(animate);

  // ── Scroll → update targets ──
  window.addEventListener("scroll", computeTargets, { passive: true });
  window.addEventListener("resize", () => {
    updateDimensions();
    computeTargets();
  });

  // ── Filters ──
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;
      filterBtns.forEach((b) => b.setAttribute("aria-pressed", "false"));
      btn.setAttribute("aria-pressed", "true");

      allCards.forEach((card) => {
        const match = filter === "all" || card.dataset.category === filter;
        card.classList.toggle("is-hidden", !match);
      });

      // Reset lerp state so it doesn't animate from old position
      currentX = 0;
      targetX = 0;
      currentBar = 0;
      targetBar = 0;

      updateDimensions();
      section.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });

  updateDimensions();
  computeTargets();
</script>

<style>
  /* ═══════════════════════════════════════
     HERO
     ═══════════════════════════════════════ */
  .vhero {
    padding-bottom: 0;
    border-bottom: none;
  }

  .vhero__inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-lg);
    padding-bottom: var(--space-xl);
    position: relative;
    z-index: 2;
  }

  .vhero__title {
    font-size: var(--text-hero);
    line-height: 0.88;

    margin-top: var(--space-xs);
  }

  .vhero__desc {
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    max-width: 42ch;
    line-height: 1.75;
  }

  .vhero__counter {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0;
    flex-shrink: 0;
  }

  .vhero__counter-num {
    font-family: var(--font-display);
    font-size: clamp(4rem, 3rem + 5vw, 8rem);
    font-weight: 800;
    line-height: 0.85;
    letter-spacing: -0.04em;
    color: var(--color-sunset);
    opacity: 0.18;
  }

  .vhero__counter-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-top: -0.2em;
  }

  .vhero__line {
    width: 100%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--color-sunset) 20%,
      var(--color-sunset) 80%,
      transparent
    );
    opacity: 0.3;
    position: relative;
    z-index: 2;
  }

  /* ═══════════════════════════════════════
     FILTERS
     ═══════════════════════════════════════ */
  .hscroll__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
    padding-block: var(--space-md);
    flex-shrink: 0;
  }

  .vfilters__btn:focus-visible {
    outline: 2px solid var(--color-sunset);
    outline-offset: 2px;
  }

  .vfilters__btn[aria-pressed="true"] {
    color: var(--color-text);
    background: var(--color-sunset-glow);
    border-color: rgba(212, 168, 83, 0.3);
    box-shadow: 0 0 16px -4px rgba(212, 168, 83, 0.15);
  }

  /* ═══════════════════════════════════════
     HORIZONTAL SCROLL
     ═══════════════════════════════════════ */
  .hscroll {
    position: relative;
  }

  .hscroll__sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .hscroll__track {
    display: flex;
    flex: 1;
    min-height: 0;
    will-change: transform;
  }

  .hscroll__bar {
    height: 2px;
    background: var(--color-border);
    flex-shrink: 0;
  }

  .hscroll__bar-fill {
    height: 100%;
    width: 0%;
    background: var(--color-sunset);
  }

  /* ═══════════════════════════════════════
     VIDEO CARDS
     ═══════════════════════════════════════ */
  .vcard {
    flex: 0 0 100vw;
    width: 100vw;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--gutter);
  }

  .vcard.is-hidden {
    display: none;
  }

  .vcard__inner {
    width: 100%;
    max-width: 900px;
    will-change: transform, opacity;
    transition:
      transform 0.15s ease-out,
      opacity 0.15s ease-out;
  }

  .vcard__embed {
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 8px 40px -12px rgba(0, 0, 0, 0.6);
  }

  .vcard__embed-fallback {
    min-height: clamp(260px, 48vw, 500px);
    display: grid;
    align-content: center;
    justify-items: start;
    gap: var(--space-xs);
    padding: clamp(1.5rem, 3vw, 2.4rem);
    text-decoration: none;
    color: var(--color-text);
    background:
      radial-gradient(
        circle at top right,
        rgba(212, 168, 83, 0.22),
        transparent 36%
      ),
      linear-gradient(
        145deg,
        rgba(255, 255, 255, 0.04),
        rgba(255, 255, 255, 0.015)
      );
  }

  .vcard__embed-fallback strong {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 2vw, 2.4rem);
    line-height: 1.05;
  }

  .vcard__embed-fallback span:last-child {
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-sunset);
    font-size: var(--text-xs);
  }

  .vcard__footer {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    padding-top: var(--space-md);
  }

  .vcard__num {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--color-sunset);
    opacity: 0.35;
  }

  .vcard__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: -0.01em;
    flex: 1;
    min-width: 0;
  }

  .vcard__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-sunset);
    white-space: nowrap;
    flex-shrink: 0;
    transition: gap 0.3s var(--ease-out-expo);
  }

  .vcard__link:hover {
    gap: 0.85em;
  }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 768px) {
    .vhero__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .vhero__counter {
      align-items: flex-start;
    }

    .hscroll__sticky {
      position: static;
      height: auto;
    }

    .hscroll__track {
      flex-direction: column;
      gap: var(--space-xl);
      padding-block: var(--space-lg);
    }

    .vcard {
      flex: none;
      width: 100%;
      height: auto;
      padding: 0 var(--gutter);
    }

    .vcard__footer {
      flex-wrap: wrap;
      gap: var(--space-xs);
    }

    .hscroll__bar {
      display: none;
    }
  }

  /* ═══════════════════════════════════════
     REDUCED MOTION
     ═══════════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .hscroll__track {
      will-change: auto;
    }
  }
</style>

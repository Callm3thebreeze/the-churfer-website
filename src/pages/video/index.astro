---
import BaseLayout from "../../layouts/BaseLayout.astro";
import YouTubeEmbed from "../../components/YouTubeEmbed.astro";
import {
  videos,
  videoCategories as categories,
  formatDate,
} from "../../data/videos";

const totalLabel = videos.length.toString().padStart(2, "0");
---

<BaseLayout
  title="Vídeo"
  description="Producciones audiovisuales de Sergi Ortega — The Churfer. Vídeo comercial para marcas, videoclips musicales y cobertura de eventos deportivos."
>
  <!-- ═══ HERO ═══ -->
  <section class="vhero">
    <div class="vhero__inner container">
      <div class="vhero__text">
        <span class="label reveal">Portfolio</span>
        <h1 class="vhero__title reveal">Vídeo</h1>
        <p class="vhero__desc reveal">
          Vídeo comercial para empresas, videoclips musicales y cobertura de
          eventos deportivos. Grabación y edición con un enfoque
          cinematográfico.
        </p>
      </div>
      <div class="vhero__counter reveal">
        <span class="vhero__counter-num">{totalLabel}</span>
        <span class="vhero__counter-label">producciones</span>
      </div>
    </div>
    <div class="vhero__line"></div>
  </section>

  <!-- ═══ FILTERS ═══ -->
  <nav class="vfilters container reveal" aria-label="Filtrar por tipo">
    {
      categories.map(({ id, label }) => (
        <button
          class="vfilters__btn"
          data-filter={id}
          aria-pressed={id === "all" ? "true" : "false"}
        >
          {label}
        </button>
      ))
    }
  </nav>

  <!-- ═══ FILM INDEX ═══ -->
  <section class="film-index container" aria-label="Lista de producciones">
    {
      videos.map((video, i) => (
        <article
          class={`film-row reveal ${i === 0 ? "is-expanded" : ""}`}
          data-category={video.category}
          data-index={i}
        >
          {/* ── Header (always visible) ── */}
          <button
            class="film-row__header"
            aria-expanded={i === 0 ? "true" : "false"}
            aria-controls={`film-body-${i}`}
          >
            <span class="film-row__num">
              {(i + 1).toString().padStart(2, "0")}
            </span>
            <div class="film-row__titles">
              <h2 class="film-row__title">{video.title}</h2>
              <span class="film-row__cat label">
                {categories.find((c) => c.id === video.category)?.label}
              </span>
            </div>
            <time class="film-row__date" datetime={video.date}>
              {formatDate(video.date)}
            </time>
            <span class="film-row__toggle" aria-hidden="true">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path d="M12 5v14M5 12h14" />
              </svg>
            </span>
          </button>

          {/* ── Body (expandable) ── */}
          <div class="film-row__body" id={`film-body-${i}`}>
            <div class="film-row__body-inner">
              <div class="film-row__embed">
                <YouTubeEmbed videoId={video.youtubeId} title={video.title} />
              </div>
              <div class="film-row__info">
                <p class="film-row__desc">{video.description}</p>
                <a href={`/video/${video.slug}`} class="film-row__link">
                  Ver proyecto completo
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path d="M5 12h14M12 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>

<script>
  const rows = document.querySelectorAll<HTMLElement>(".film-row");
  const btns = document.querySelectorAll<HTMLButtonElement>(".vfilters__btn");

  // ── Accordion ──
  function toggleRow(row: HTMLElement, forceOpen?: boolean) {
    const header = row.querySelector<HTMLButtonElement>(".film-row__header")!;
    const isOpen = row.classList.contains("is-expanded");
    const shouldOpen = forceOpen ?? !isOpen;

    if (shouldOpen && !isOpen) {
      // Close others first
      rows.forEach((r) => {
        if (r !== row && r.classList.contains("is-expanded")) {
          r.classList.remove("is-expanded");
          r.querySelector<HTMLButtonElement>(".film-row__header")!.setAttribute(
            "aria-expanded",
            "false",
          );
        }
      });
      row.classList.add("is-expanded");
      header.setAttribute("aria-expanded", "true");
    } else if (!shouldOpen && isOpen) {
      row.classList.remove("is-expanded");
      header.setAttribute("aria-expanded", "false");
    }
  }

  rows.forEach((row) => {
    const header = row.querySelector<HTMLButtonElement>(".film-row__header")!;
    header.addEventListener("click", () => toggleRow(row));
  });

  // ── Filters ──
  btns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;
      btns.forEach((b) => b.setAttribute("aria-pressed", "false"));
      btn.setAttribute("aria-pressed", "true");

      let firstVisible: HTMLElement | null = null;

      rows.forEach((row) => {
        const match = filter === "all" || row.dataset.category === filter;
        row.classList.toggle("is-hidden", !match);
        if (match && !firstVisible) firstVisible = row;

        // Close all during filter
        if (row.classList.contains("is-expanded")) {
          row.classList.remove("is-expanded");
          row
            .querySelector<HTMLButtonElement>(".film-row__header")!
            .setAttribute("aria-expanded", "false");
        }
      });

      // Open first visible
      if (firstVisible) {
        toggleRow(firstVisible, true);
      }
    });
  });
</script>

<style>
  /* ═══════════════════════════════════════
     HERO
     ═══════════════════════════════════════ */
  .vhero {
    padding-top: calc(var(--space-section) + 80px);
    padding-bottom: 0;
    position: relative;
    overflow: hidden;
  }

  .vhero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      #0c1a2a 0%,
      #0a1520 30%,
      #162430 60%,
      #0d1a25 100%
    );
    animation: heroShift 20s ease-in-out infinite alternate;
    z-index: 0;
  }

  .vhero::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, var(--color-bg) 0%, transparent 50%),
      linear-gradient(to right, rgba(10, 10, 10, 0.5) 0%, transparent 60%);
    z-index: 1;
  }

  @keyframes heroShift {
    0% {
      filter: brightness(0.9) hue-rotate(0deg);
    }
    100% {
      filter: brightness(1.1) hue-rotate(8deg);
    }
  }

  .vhero__inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-lg);
    padding-bottom: var(--space-xl);
    position: relative;
    z-index: 2;
  }

  .vhero__title {
    font-size: var(--text-hero);
    line-height: 0.88;

    margin-top: var(--space-xs);
  }

  .vhero__desc {
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    max-width: 42ch;
    line-height: 1.75;
  }

  .vhero__counter {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0;
    flex-shrink: 0;
  }

  .vhero__counter-num {
    font-family: var(--font-display);
    font-size: clamp(4rem, 3rem + 5vw, 8rem);
    font-weight: 800;
    line-height: 0.85;
    letter-spacing: -0.04em;
    color: var(--color-sunset);
    opacity: 0.18;
  }

  .vhero__counter-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-top: -0.2em;
  }

  .vhero__line {
    width: 100%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--color-sunset) 20%,
      var(--color-sunset) 80%,
      transparent
    );
    opacity: 0.3;
    position: relative;
    z-index: 2;
  }

  /* ═══════════════════════════════════════
     FILTERS
     ═══════════════════════════════════════ */
  .vfilters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
    padding-block: var(--space-lg) var(--space-md);
  }

  .vfilters__btn {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.65em 1.5em;
    color: var(--color-text-dim);
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 100px;
    cursor: pointer;
    transition:
      color 0.3s var(--ease-out-expo),
      background 0.3s var(--ease-out-expo),
      border-color 0.3s var(--ease-out-expo),
      box-shadow 0.3s var(--ease-out-expo);
  }

  .vfilters__btn:hover {
    color: var(--color-text-muted);
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .vfilters__btn:focus-visible {
    outline: 2px solid var(--color-sunset);
    outline-offset: 2px;
  }

  .vfilters__btn[aria-pressed="true"] {
    color: var(--color-text);
    background: rgba(212, 168, 83, 0.12);
    border-color: rgba(212, 168, 83, 0.3);
    box-shadow: 0 0 16px -4px rgba(212, 168, 83, 0.15);
  }

  /* ═══════════════════════════════════════
     FILM INDEX
     ═══════════════════════════════════════ */
  .film-index {
    padding-bottom: var(--space-section);
  }

  /* ── Row ── */
  .film-row {
    border-top: 1px solid var(--color-border);
    transition: opacity 0.4s var(--ease-out-expo);
  }

  .film-row:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .film-row.is-hidden {
    display: none;
  }

  /* ── Header ── */
  .film-row__header {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: var(--space-md);
    width: 100%;
    padding: var(--space-md) 0;
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    text-align: left;
    transition: background 0.3s var(--ease-out-expo);
  }

  .film-row__header:hover {
    background: rgba(255, 255, 255, 0.02);
  }

  .film-row__header:focus-visible {
    outline: 2px solid var(--color-sunset);
    outline-offset: -2px;
  }

  /* Number */
  .film-row__num {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 1.5rem + 1.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--color-text-dim);
    opacity: 0.25;
    min-width: 2.2em;
    transition:
      color 0.4s var(--ease-out-expo),
      opacity 0.4s var(--ease-out-expo);
  }

  .film-row__header:hover .film-row__num,
  .film-row.is-expanded .film-row__num {
    color: var(--color-sunset);
    opacity: 0.7;
  }

  /* Titles block */
  .film-row__titles {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    min-width: 0;
  }

  .film-row__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
    overflow-wrap: break-word;
    word-break: break-word;
    transition: color 0.3s var(--ease-out-expo);
  }

  .film-row__header:hover .film-row__title {
    color: var(--color-text);
  }

  .film-row__cat {
    flex-shrink: 0;
  }

  /* Date */
  .film-row__date {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-style: italic;
    color: var(--color-text-dim);
    white-space: nowrap;
  }

  /* Toggle icon */
  .film-row__toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    color: var(--color-text-dim);
    flex-shrink: 0;
    transition:
      transform 0.5s var(--ease-out-expo),
      border-color 0.3s var(--ease-out-expo),
      color 0.3s var(--ease-out-expo),
      background 0.3s var(--ease-out-expo);
  }

  .film-row__header:hover .film-row__toggle {
    border-color: var(--color-border-strong);
    color: var(--color-text-muted);
  }

  .film-row.is-expanded .film-row__toggle {
    transform: rotate(45deg);
    border-color: var(--color-sunset);
    color: var(--color-sunset);
    background: rgba(212, 168, 83, 0.08);
  }

  /* ── Body (expandable) ── */
  .film-row__body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.6s var(--ease-out-expo);
  }

  .film-row.is-expanded .film-row__body {
    grid-template-rows: 1fr;
  }

  .film-row__body-inner {
    overflow: hidden;
  }

  /* Content inside body */
  .film-row__embed {
    padding-bottom: var(--space-md);
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.5s var(--ease-out-expo) 0.15s,
      transform 0.5s var(--ease-out-expo) 0.15s;
  }

  .film-row.is-expanded .film-row__embed {
    opacity: 1;
    transform: translateY(0);
  }

  .film-row__info {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-lg);
    padding-bottom: var(--space-lg);
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.5s var(--ease-out-expo) 0.25s,
      transform 0.5s var(--ease-out-expo) 0.25s;
  }

  .film-row.is-expanded .film-row__info {
    opacity: 1;
    transform: translateY(0);
  }

  .film-row__desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    max-width: 60ch;
  }

  .film-row__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-sunset);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.3em;
    transition: gap 0.3s var(--ease-out-expo);
  }

  .film-row__link:hover {
    gap: 0.85em;
  }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 768px) {
    .vhero__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .vhero__counter {
      align-items: flex-start;
    }

    .film-row__header {
      grid-template-columns: auto 1fr auto;
      gap: var(--space-sm);
      overflow: hidden;
    }

    .film-row__date {
      display: none;
    }

    .film-row__titles {
      flex-direction: column;
      gap: 0.2em;
    }

    .film-row__title {
      font-size: var(--text-lg);
    }

    .film-row__num {
      font-size: clamp(1.4rem, 1.2rem + 1vw, 2rem);
    }

    .film-row__toggle {
      width: 34px;
      height: 34px;
    }

    .film-row__toggle svg {
      width: 18px;
      height: 18px;
    }

    .film-row__info {
      flex-direction: column;
      gap: var(--space-sm);
    }
  }

  /* ═══════════════════════════════════════
     REDUCED MOTION
     ═══════════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .film-row__body {
      transition-duration: 0.01ms;
    }

    .film-row__embed,
    .film-row__info {
      transition-duration: 0.01ms;
      transition-delay: 0ms;
    }

    .film-row__toggle {
      transition-duration: 0.01ms;
    }
  }
</style>

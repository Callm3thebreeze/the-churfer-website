---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Datos de ejemplo — reemplazar por fetch a Emdash cuando esté configurado
const categories = [
  { id: "all", label: "Todo" },
  { id: "surf", label: "Surf & Mar" },
  { id: "sport", label: "Deportes" },
  { id: "portrait", label: "Retratos" },
  { id: "event", label: "Eventos" },
];

const photos = [
  { id: 1, title: "Barrel al amanecer", category: "surf", aspect: "3/4" },
  { id: 2, title: "Cutback en El Palmar", category: "surf", aspect: "16/10" },
  { id: 3, title: "Sumisión en el tatami", category: "sport", aspect: "3/4" },
  {
    id: 4,
    title: "Aerial sobre la sección",
    category: "surf",
    aspect: "16/10",
  },
  { id: 5, title: "Kickflip en el bowl", category: "sport", aspect: "16/10" },
  { id: 6, title: "Retrato con neopreno", category: "portrait", aspect: "3/4" },
  {
    id: 7,
    title: "Bottom turn al atardecer",
    category: "surf",
    aspect: "16/10",
  },
  {
    id: 8,
    title: "Campeonato de jiu-jitsu",
    category: "event",
    aspect: "16/10",
  },
  { id: 9, title: "Tubo desde dentro", category: "surf", aspect: "3/4" },
  { id: 10, title: "Ollie en la calle", category: "sport", aspect: "16/10" },
  { id: 11, title: "Retrato en la playa", category: "portrait", aspect: "3/4" },
  { id: 12, title: "Océano al amanecer", category: "surf", aspect: "16/10" },
];

// Clases de tamaño para la vista panorámica
const tileClasses = photos.map((photo, i) => {
  if (i === 3 || i === 9) return "pano-tile--lg";
  if (photo.aspect === "3/4") return "pano-tile--tall";
  if ([1, 4, 7, 11].includes(i)) return "pano-tile--wide";
  return "";
});
---

<BaseLayout
  title="Fotografía"
  description="Portfolio de fotografía deportiva de Sergi Ortega — The Churfer. Surf, foto marina, jiu-jitsu, skate y más. Desde El Palmar, Cádiz."
>
  <!-- ═══ PAGE HERO ═══ -->
  <section class="page-hero">
    <div class="page-hero__inner container">
      <span class="label reveal">Portfolio</span>
      <h1 class="reveal">Fotografía</h1>
      <p class="page-hero__desc reveal">
        Surf, foto marina, jiu-jitsu, skate — capturo deportes de acción con la
        intensidad que merecen. Dentro del agua, al borde del tatami o en el
        bowl, mi cámara está donde pasa la acción.
      </p>
      <div class="rule reveal"></div>
    </div>
  </section>

  <!-- ═══ TOOLBAR ═══ -->
  <div class="gallery-toolbar container reveal">
    <nav class="filters" aria-label="Filtrar por categoría">
      {
        categories.map(({ id, label }) => (
          <button
            class="filters__btn"
            data-filter={id}
            aria-pressed={id === "all" ? "true" : "false"}
          >
            {label}
          </button>
        ))
      }
    </nav>
    <button class="panorama-trigger" id="panorama-open" type="button">
      <svg
        width="16"
        height="16"
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.4"
      >
        <rect x="1" y="1" width="5.5" height="5.5" rx="0.5"></rect>
        <rect x="9.5" y="1" width="5.5" height="5.5" rx="0.5"></rect>
        <rect x="1" y="9.5" width="5.5" height="5.5" rx="0.5"></rect>
        <rect x="9.5" y="9.5" width="5.5" height="5.5" rx="0.5"></rect>
      </svg>
      Vista global
    </button>
  </div>

  <!-- ═══ GALLERY ═══ -->
  <section class="gallery container">
    <div class="gallery__grid">
      {
        photos.map((photo, i) => (
          <article
            class={`gallery__item reveal reveal-delay-${(i % 4) + 1}`}
            data-category={photo.category}
            data-index={i}
            role="button"
            tabindex="0"
            aria-label={`Ver ${photo.title}`}
          >
            <div class="gallery__item-media">
              <div
                class="gallery__placeholder"
                style={`aspect-ratio: ${photo.aspect};`}
              >
                <span class="gallery__placeholder-icon">&#9744;</span>
              </div>
              <div class="gallery__overlay">
                <h3 class="gallery__overlay-title">{photo.title}</h3>
                <span class="gallery__overlay-cat">
                  {categories.find((c) => c.id === photo.category)?.label}
                </span>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ═══ LIGHTBOX ═══ -->
  <div
    class="lightbox"
    id="lightbox"
    aria-hidden="true"
    role="dialog"
    aria-label="Galería ampliada"
  >
    <button class="lightbox__close" aria-label="Cerrar galería">
      <svg
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>
    <button
      class="lightbox__arrow lightbox__arrow--prev"
      aria-label="Imagen anterior"
    >
      <svg
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path d="M15 18l-6-6 6-6"></path>
      </svg>
    </button>
    <button
      class="lightbox__arrow lightbox__arrow--next"
      aria-label="Imagen siguiente"
    >
      <svg
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path d="M9 18l6-6-6-6"></path>
      </svg>
    </button>
    <div class="lightbox__content">
      <div class="lightbox__placeholder" id="lightbox-image">
        <span class="gallery__placeholder-icon">&#9744;</span>
      </div>
      <div class="lightbox__info" id="lightbox-info">
        <h3 class="lightbox__title" id="lightbox-title"></h3>
        <span class="lightbox__cat label" id="lightbox-cat"></span>
        <span class="lightbox__counter" id="lightbox-counter"></span>
      </div>
    </div>
  </div>

  <!-- ═══ PANORAMA (Vista Global) ═══ -->
  <div
    class="panorama"
    id="panorama"
    aria-hidden="true"
    role="dialog"
    aria-label="Vista global de fotografías"
  >
    <div class="panorama__header">
      <span class="panorama__label label">Vista global</span>
      <button
        class="panorama__close"
        id="panorama-close"
        aria-label="Cerrar vista global"
      >
        <svg
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path d="M18 6L6 18M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <div class="panorama__scroll" id="panorama-scroll">
      <div class="panorama__canvas" id="panorama-canvas">
        {
          photos.map((photo, i) => (
            <div
              class={`pano-tile ${tileClasses[i]}`}
              data-pano-index={i}
              style={`transition-delay: ${0.06 + i * 0.04}s`}
            >
              <div class="pano-tile__media">
                <div class="pano-tile__placeholder">
                  <span class="gallery__placeholder-icon">&#9744;</span>
                </div>
                <div class="pano-tile__overlay">
                  <h3 class="pano-tile__title">{photo.title}</h3>
                  <span class="pano-tile__cat">
                    {categories.find((c) => c.id === photo.category)?.label}
                  </span>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
    <div class="panorama__edge panorama__edge--top"></div>
    <div class="panorama__edge panorama__edge--right"></div>
    <div class="panorama__edge panorama__edge--bottom"></div>
    <div class="panorama__edge panorama__edge--left"></div>
  </div>
</BaseLayout>

<script>
  const grid = document.querySelector<HTMLElement>(".gallery__grid")!;
  const btns = document.querySelectorAll<HTMLButtonElement>(".filters__btn");
  const items = Array.from(
    document.querySelectorAll<HTMLElement>(".gallery__item"),
  );

  // ── Masonry: shortest column first ──
  function getColCount(): number {
    const w = grid.offsetWidth;
    if (w < 540) return 1;
    if (w < 900) return 2;
    return 3;
  }

  function layoutMasonry() {
    const cols = getColCount();
    const style = getComputedStyle(document.documentElement);
    const gap = parseFloat(style.getPropertyValue("--space-xs")) * 16 || 8;
    const gridWidth = grid.offsetWidth;
    const colWidth = (gridWidth - gap * (cols - 1)) / cols;
    const colHeights = new Array(cols).fill(0);

    // Visible items — lay out in shortest column
    const visible = items.filter((el) => !el.classList.contains("hidden"));
    visible.forEach((item) => {
      const shortest = colHeights.indexOf(Math.min(...colHeights));

      item.style.width = `${colWidth}px`;
      item.style.transform = `translate(${shortest * (colWidth + gap)}px, ${colHeights[shortest]}px)`;
      item.style.opacity = "1";

      colHeights[shortest] += item.offsetHeight + gap;
    });

    // Hidden items — fade out
    items
      .filter((el) => el.classList.contains("hidden"))
      .forEach((item) => {
        item.style.opacity = "0";
        item.style.pointerEvents = "none";
      });

    // Set container height
    grid.style.height = `${Math.max(...colHeights, 0)}px`;
  }

  // Initial layout (no transitions)
  layoutMasonry();
  requestAnimationFrame(() => grid.classList.add("masonry-ready"));

  // ── Filters ──
  btns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;
      btns.forEach((b) => b.setAttribute("aria-pressed", "false"));
      btn.setAttribute("aria-pressed", "true");

      items.forEach((item) => {
        const match = filter === "all" || item.dataset.category === filter;
        item.classList.toggle("hidden", !match);
        item.style.pointerEvents = match ? "" : "none";
      });

      layoutMasonry();
    });
  });

  // ── Resize (debounced) ──
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(layoutMasonry, 100);
  });

  // ── Lightbox ──
  const lightbox = document.getElementById("lightbox")!;
  const lbTitle = document.getElementById("lightbox-title")!;
  const lbCat = document.getElementById("lightbox-cat")!;
  const lbCounter = document.getElementById("lightbox-counter")!;
  const lbImage = document.getElementById("lightbox-image")!;
  const closeBtn =
    lightbox.querySelector<HTMLButtonElement>(".lightbox__close")!;
  const prevBtn = lightbox.querySelector<HTMLButtonElement>(
    ".lightbox__arrow--prev",
  )!;
  const nextBtn = lightbox.querySelector<HTMLButtonElement>(
    ".lightbox__arrow--next",
  )!;

  let currentIndex = 0;

  function getVisibleItems(): HTMLElement[] {
    return items.filter((el) => !el.classList.contains("hidden"));
  }

  function showImage(index: number) {
    const visible = getVisibleItems();
    if (visible.length === 0) return;
    currentIndex = ((index % visible.length) + visible.length) % visible.length;
    const item = visible[currentIndex];
    const placeholder = item.querySelector<HTMLElement>(
      ".gallery__placeholder",
    );

    lbTitle.textContent =
      item.querySelector<HTMLElement>(".gallery__overlay-title")?.textContent ??
      "";
    lbCat.textContent =
      item.querySelector<HTMLElement>(".gallery__overlay-cat")?.textContent ??
      "";
    lbCounter.textContent = `${currentIndex + 1} / ${visible.length}`;

    if (placeholder) {
      lbImage.style.aspectRatio = placeholder.style.aspectRatio;
    }
  }

  function openLightbox(index: number) {
    showImage(index);
    lightbox.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    closeBtn.focus();
  }

  function closeLightbox() {
    lightbox.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  items.forEach((item) => {
    const handler = () => {
      const visible = getVisibleItems();
      const idx = visible.indexOf(item);
      if (idx !== -1) openLightbox(idx);
    };
    item.addEventListener("click", handler);
    item.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        handler();
      }
    });
  });

  prevBtn.addEventListener("click", () => showImage(currentIndex - 1));
  nextBtn.addEventListener("click", () => showImage(currentIndex + 1));
  closeBtn.addEventListener("click", closeLightbox);

  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  // ── Panorama (Vista Global) ──
  const panorama = document.getElementById("panorama")!;
  const panoScroll = document.getElementById("panorama-scroll")!;
  const panoCanvas = document.getElementById("panorama-canvas")!;
  const panoOpen = document.getElementById("panorama-open")!;
  const panoCl = document.getElementById("panorama-close")!;
  const panoEdges = {
    top: panorama.querySelector<HTMLElement>(".panorama__edge--top")!,
    right: panorama.querySelector<HTMLElement>(".panorama__edge--right")!,
    bottom: panorama.querySelector<HTMLElement>(".panorama__edge--bottom")!,
    left: panorama.querySelector<HTMLElement>(".panorama__edge--left")!,
  };

  const EDGE_ZONE = 100;
  const MAX_SPEED = 14;
  let panoRAF: number | null = null;
  let panoMouseX = window.innerWidth / 2;
  let panoMouseY = window.innerHeight / 2;

  function openPanorama() {
    panorama.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    requestAnimationFrame(() => {
      panoScroll.scrollLeft =
        (panoCanvas.scrollWidth - panoScroll.clientWidth) / 2;
      panoScroll.scrollTop =
        (panoCanvas.scrollHeight - panoScroll.clientHeight) / 2;
      startEdgeScroll();
    });
  }

  function closePanorama() {
    stopEdgeScroll();
    panorama.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  function startEdgeScroll() {
    function tick() {
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      let vx = 0,
        vy = 0;

      if (panoMouseX < EDGE_ZONE) {
        vx = -MAX_SPEED * Math.pow(1 - panoMouseX / EDGE_ZONE, 1.5);
      } else if (panoMouseX > vw - EDGE_ZONE) {
        vx = MAX_SPEED * Math.pow(1 - (vw - panoMouseX) / EDGE_ZONE, 1.5);
      }

      if (panoMouseY < EDGE_ZONE) {
        vy = -MAX_SPEED * Math.pow(1 - panoMouseY / EDGE_ZONE, 1.5);
      } else if (panoMouseY > vh - EDGE_ZONE) {
        vy = MAX_SPEED * Math.pow(1 - (vh - panoMouseY) / EDGE_ZONE, 1.5);
      }

      if (vx !== 0 || vy !== 0) {
        panoScroll.scrollLeft += vx;
        panoScroll.scrollTop += vy;
      }

      const canLeft = panoScroll.scrollLeft > 0;
      const canRight =
        panoScroll.scrollLeft <
        panoScroll.scrollWidth - panoScroll.clientWidth - 1;
      const canTop = panoScroll.scrollTop > 0;
      const canBottom =
        panoScroll.scrollTop <
        panoScroll.scrollHeight - panoScroll.clientHeight - 1;

      panoEdges.left.classList.toggle(
        "is-active",
        panoMouseX < EDGE_ZONE && canLeft,
      );
      panoEdges.right.classList.toggle(
        "is-active",
        panoMouseX > vw - EDGE_ZONE && canRight,
      );
      panoEdges.top.classList.toggle(
        "is-active",
        panoMouseY < EDGE_ZONE && canTop,
      );
      panoEdges.bottom.classList.toggle(
        "is-active",
        panoMouseY > vh - EDGE_ZONE && canBottom,
      );

      panoRAF = requestAnimationFrame(tick);
    }
    panoRAF = requestAnimationFrame(tick);
  }

  function stopEdgeScroll() {
    if (panoRAF !== null) {
      cancelAnimationFrame(panoRAF);
      panoRAF = null;
    }
    Object.values(panoEdges).forEach((el) => el.classList.remove("is-active"));
  }

  panorama.addEventListener("mousemove", (e) => {
    panoMouseX = e.clientX;
    panoMouseY = e.clientY;
  });

  panoOpen.addEventListener("click", openPanorama);
  panoCl.addEventListener("click", closePanorama);

  // ── Keyboard (unified) ──
  document.addEventListener("keydown", (e) => {
    if (lightbox.getAttribute("aria-hidden") !== "true") {
      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowLeft") showImage(currentIndex - 1);
      if (e.key === "ArrowRight") showImage(currentIndex + 1);
      return;
    }
    if (panorama.getAttribute("aria-hidden") !== "true") {
      if (e.key === "Escape") closePanorama();
    }
  });
</script>

<style>
  /* ═══ PAGE HERO ═══ */
  .page-hero {
    padding-top: calc(var(--space-section) + 80px);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .page-hero h1 {
    margin-top: var(--space-xs);
  }

  .page-hero__desc {
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    max-width: 55ch;
    line-height: 1.8;
  }

  .page-hero .rule {
    margin-top: var(--space-md);
  }

  /* ═══ TOOLBAR ═══ */
  .gallery-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-lg);
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  /* ═══ FILTERS ═══ */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
  }

  .filters__btn {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.65em 1.5em;
    color: var(--color-text-dim);
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 100px;
    cursor: pointer;
    transition:
      color 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .filters__btn:hover {
    color: var(--color-text-muted);
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .filters__btn:focus-visible {
    outline: 2px solid var(--color-sunset);
    outline-offset: 2px;
  }

  .filters__btn[aria-pressed="true"] {
    color: var(--color-text);
    background: rgba(212, 168, 83, 0.12);
    border-color: rgba(212, 168, 83, 0.3);
    box-shadow: 0 0 16px -4px rgba(212, 168, 83, 0.15);
  }

  /* ═══ GALLERY ═══ */
  .gallery {
    padding-bottom: var(--space-section);
  }

  .gallery__grid {
    position: relative;
  }

  .gallery__item {
    position: absolute;
    cursor: pointer;
    outline: none;
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .gallery__grid:not(.masonry-ready) .gallery__item {
    transition: none;
  }

  .gallery__item:focus-visible .gallery__placeholder {
    outline: 2px solid var(--color-sunset);
    outline-offset: 2px;
  }

  /* ── Item media (hover zoom + overlay) ── */
  .gallery__item-media {
    position: relative;
    overflow: hidden;
  }

  .gallery__placeholder {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      filter 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .gallery__item:hover .gallery__placeholder {
    transform: scale(1.06);
    filter: brightness(0.75);
  }

  .gallery__placeholder-icon {
    font-size: var(--text-2xl);
    color: var(--color-text-dim);
    opacity: 0.3;
  }

  /* ── Info overlay (bottom-left) ── */
  .gallery__overlay {
    position: absolute;
    inset: auto auto 0 0;
    width: 100%;
    padding: var(--space-lg) var(--space-md) var(--space-sm);
    background: linear-gradient(
      to top,
      rgba(6, 6, 6, 0.85) 0%,
      transparent 100%
    );
    display: flex;
    flex-direction: column;
    gap: 0.25em;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    pointer-events: none;
  }

  .gallery__item:hover .gallery__overlay {
    opacity: 1;
    transform: translateY(0);
  }

  .gallery__overlay-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.2;
  }

  .gallery__overlay-cat {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-sunset);
  }

  /* ═══ LIGHTBOX ═══ */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(6, 6, 6, 0.94);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    opacity: 1;
    visibility: visible;
    transition:
      opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 0s,
      backdrop-filter 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .lightbox[aria-hidden="true"] {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    transition:
      opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 0.4s,
      backdrop-filter 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .lightbox__close {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    color: var(--color-text-muted);
    background: none;
    border: none;

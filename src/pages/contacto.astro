---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contacto"
  description="Contacta con Sergi Ortega — The Churfer para fotografía deportiva, vídeo comercial, videoclips musicales o cobertura de eventos."
>
  <!-- ═══ PAGE HERO ═══ -->
  <section class="page-hero">
    <div class="page-hero__inner container">
      <span class="label reveal">Hablemos</span>
      <h1 class="reveal">Contacto</h1>
      <p class="page-hero__desc reveal">
        ¿Necesitas fotografía deportiva, un vídeo comercial para tu marca, un
        videoclip o cobertura de un evento? Escríbeme y hablamos.
      </p>
      <div class="rule reveal"></div>
    </div>
  </section>

  <!-- ═══ CONTACT CONTENT ═══ -->
  <section class="contact container">
    <div class="contact__grid">
      <!-- FORMULARIO -->
      <form class="contact__form reveal" method="POST" action="#">
        <div class="contact__form-group">
          <label for="name">Nombre</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            placeholder="Tu nombre"
          />
        </div>

        <div class="contact__form-group">
          <label for="email">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder="tu@email.com"
          />
        </div>

        <div class="contact__form-group">
          <label for="subject">¿En qué puedo ayudarte?</label>
          <select id="subject" name="subject" required>
            <option value="">Selecciona una opción</option>
            <option value="foto-deportiva">Fotografía deportiva</option>
            <option value="video-comercial">Vídeo comercial</option>
            <option value="videoclip">Videoclip musical</option>
            <option value="evento">Cobertura de evento</option>
            <option value="colaboracion">Colaboración / Marca</option>
            <option value="otro">Otro</option>
          </select>
        </div>

        <div class="contact__form-group">
          <label for="message">Mensaje</label>
          <textarea
            id="message"
            name="message"
            rows="6"
            required
            placeholder="Cuéntame sobre tu proyecto..."></textarea>
        </div>

        <button type="submit" class="cta-button">Enviar mensaje</button>
      </form>

      <!-- SIDEBAR INFO -->
      <aside class="contact__aside reveal">
        <div class="contact__info-block">
          <h2 class="contact__info-heading">Encuéntrame</h2>
          <p class="contact__info-text">
            Basado en El Palmar, Cádiz. Disponible para proyectos en cualquier
            punto de la península y fuera de ella.
          </p>
        </div>

        <div class="contact__info-block">
          <h3 class="label">Redes sociales</h3>
          <ul class="contact__social">
            <li>
              <a
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                class="contact__social-link"
              >
                <span class="contact__social-icon">IG</span>
                Instagram
              </a>
            </li>
            <li>
              <a
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                class="contact__social-link"
              >
                <span class="contact__social-icon">YT</span>
                YouTube
              </a>
            </li>
          </ul>
        </div>

        <div class="contact__info-block">
          <h3 class="label">Respuesta habitual</h3>
          <p class="contact__info-text">
            Normalmente respondo en menos de 24h. Para proyectos urgentes,
            indícalo en el mensaje.
          </p>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  /* ═══ PAGE HERO ═══ */
  .page-hero {
    padding-top: calc(var(--space-md) + 80px);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .page-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      #0c1a2a 0%,
      #0a1520 30%,
      #162430 60%,
      #0d1a25 100%
    );
    animation: heroShift 20s ease-in-out infinite alternate;
    z-index: 0;
  }

  .page-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, var(--color-bg) 0%, transparent 50%),
      linear-gradient(to right, rgba(10, 10, 10, 0.5) 0%, transparent 60%);
    z-index: 1;
  }

  .page-hero__inner {
    position: relative;
    z-index: 2;
  }

  @keyframes heroShift {
    0% {
      filter: brightness(0.9) hue-rotate(0deg);
    }
    100% {
      filter: brightness(1.1) hue-rotate(8deg);
    }
  }

  .page-hero h1 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2xs);
  }

  .page-hero__desc {
    color: var(--color-text-muted);
    margin-top: var(--space-2xs);
    max-width: 55ch;
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .page-hero .rule {
    margin-top: var(--space-xs);
  }

  /* ═══ CONTACT LAYOUT ═══ */
  .contact {
    padding-block: var(--space-lg);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  /* ═══ FORM ═══ */
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact__form-group {
    display: flex;
    flex-direction: column;
  }

  .contact__form input::placeholder,
  .contact__form textarea::placeholder {
    color: var(--color-text-dim);
    opacity: 0.6;
  }

  .contact__form .cta-button {
    align-self: flex-start;
  }

  /* ═══ ASIDE ═══ */
  .contact__aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding-left: var(--space-lg);
    border-left: 1px solid var(--color-border);
  }

  .contact__info-heading {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-xs);
  }

  .contact__info-text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .contact__social {
    display: flex;
    flex-direction: column;
    gap: 0.6em;
    margin-top: var(--space-xs);
  }

  .contact__social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.7em;
    font-size: var(--text-base);
    color: var(--color-text-muted);
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .contact__social-link:hover {
    color: var(--color-sunset);
  }

  .contact__social-icon {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    width: 2.4em;
    height: 2.4em;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    transition: border-color var(--duration-fast) var(--ease-out-quart);
  }

  .contact__social-link:hover .contact__social-icon {
    border-color: var(--color-sunset);
  }

  @media (max-width: 768px) {
    .contact__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .contact__aside {
      padding-left: 0;
      border-left: none;
      border-top: 1px solid var(--color-border);
      padding-top: var(--space-lg);
    }
  }
</style>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import smallLogo from "../assets/small-logo.png";

const photos = [
	{ id: 1, title: "Barrel al amanecer", category: "surf", aspect: "3/4" },
	{ id: 2, title: "Cutback en El Palmar", category: "surf", aspect: "16/10" },
	{ id: 3, title: "Sumisión en el tatami", category: "sport", aspect: "3/4" },
	{
		id: 4,
		title: "Aerial sobre la sección",
		category: "surf",
		aspect: "16/10",
	},
	{ id: 5, title: "Kickflip en el bowl", category: "sport", aspect: "16/10" },
	{ id: 6, title: "Retrato con neopreno", category: "portrait", aspect: "3/4" },
	{
		id: 7,
		title: "Bottom turn al atardecer",
		category: "surf",
		aspect: "16/10",
	},
	{
		id: 8,
		title: "Campeonato de jiu-jitsu",
		category: "event",
		aspect: "16/10",
	},
	{ id: 9, title: "Tubo desde dentro", category: "surf", aspect: "3/4" },
	{ id: 10, title: "Ollie en la calle", category: "sport", aspect: "16/10" },
	{ id: 11, title: "Retrato en la playa", category: "portrait", aspect: "3/4" },
	{ id: 12, title: "Océano al amanecer", category: "surf", aspect: "16/10" },
];

const categories: Record<string, string> = {
	surf: "Surf & Mar",
	sport: "Deportes",
	portrait: "Retratos",
	event: "Eventos",
};

const tileClasses = photos.map((photo, i) => {
	if (i === 3 || i === 9) return "pano-tile--lg";
	if (photo.aspect === "3/4") return "pano-tile--tall";
	if ([1, 4, 7, 11].includes(i)) return "pano-tile--wide";
	return "";
});
---

<BaseLayout
	title="Sergi Ortega — Fotografía deportiva & Vídeo comercial"
	description="Sergi Ortega, fotógrafo deportivo y videógrafo profesional. Especializado en surf, foto marina, deportes de acción y producciones audiovisuales comerciales. Desde El Palmar, Cádiz."
	hideChrome
>
	<!-- ═══ FULLSCREEN GALLERY (HOME) ═══ -->
	<div class="home-pano" id="home-pano">
		<div class="home-pano__scroll" id="home-pano-scroll">
			<div class="home-pano__canvas" id="home-pano-canvas">
				{
					photos.map((photo, i) => (
						<div
							class={`pano-tile ${tileClasses[i]}`}
							data-pano-index={i}
							data-title={photo.title}
							data-cat={categories[photo.category]}
							role="button"
							tabindex="0"
							aria-label={`Ver ${photo.title}`}
							style={`transition-delay: ${0.06 + i * 0.04}s`}
						>
							<div class="pano-tile__media">
								<div class="pano-tile__placeholder">
									<span class="pano-tile__icon">&#9744;</span>
								</div>
								<div class="pano-tile__overlay">
									<h3 class="pano-tile__title">{photo.title}</h3>
									<span class="pano-tile__cat">
										{categories[photo.category]}
									</span>
								</div>
							</div>
						</div>
					))
				}
			</div>
		</div>

		<!-- Edge scroll indicators -->
		<div class="pano-edge pano-edge--top"></div>
		<div class="pano-edge pano-edge--right"></div>
		<div class="pano-edge pano-edge--bottom"></div>
		<div class="pano-edge pano-edge--left"></div>

		<!-- Vignette overlay -->
		<div class="home-pano__vignette"></div>

		<!-- Logo -->
		<a href="/sobre-mi" class="home-pano__logo" aria-label="Sobre mí">
			<img
				src={smallLogo.src}
				alt="The Churfer"
				width={smallLogo.width}
				height={smallLogo.height}
				loading="eager"
				decoding="async"
			/>
		</a>
	</div>

	<!-- ═══ LIGHTBOX (shows navbar) ═══ -->
	<div
		class="home-lb"
		id="home-lightbox"
		aria-hidden="true"
		role="dialog"
		aria-label="Imagen ampliada"
	>
		<div class="home-lb__header" id="home-lb-header">
			<Header />
		</div>

		<button
			class="home-lb__arrow home-lb__arrow--prev"
			aria-label="Imagen anterior"
		>
			<svg
				width="32"
				height="32"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.5"
			>
				<path d="M15 18l-6-6 6-6"></path>
			</svg>
		</button>
		<button
			class="home-lb__arrow home-lb__arrow--next"
			aria-label="Imagen siguiente"
		>
			<svg
				width="32"
				height="32"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.5"
			>
				<path d="M9 18l6-6-6-6"></path>
			</svg>
		</button>

		<div class="home-lb__content">
			<div class="home-lb__placeholder" id="home-lb-image">
				<span class="pano-tile__icon">&#9744;</span>
			</div>
			<div class="home-lb__info" id="home-lb-info">
				<h3 class="home-lb__title" id="home-lb-title"></h3>
				<span class="home-lb__cat label" id="home-lb-cat"></span>
				<span class="home-lb__counter" id="home-lb-counter"></span>
			</div>
		</div>

		<button
			class="home-lb__back"
			id="home-lb-back"
			aria-label="Volver a galería"
		>
			<svg
				width="20"
				height="20"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.5"
			>
				<path d="M19 12H5M12 19l-7-7 7-7"></path>
			</svg>
			<span>Galería</span>
		</button>
	</div>
</BaseLayout>

<script>
	// ── Panorama edge-scroll ──
	const panoScroll = document.getElementById("home-pano-scroll")!;
	const panoCanvas = document.getElementById("home-pano-canvas")!;
	const panoEdges = {
		top: document.querySelector<HTMLElement>(".pano-edge--top")!,
		right: document.querySelector<HTMLElement>(".pano-edge--right")!,
		bottom: document.querySelector<HTMLElement>(".pano-edge--bottom")!,
		left: document.querySelector<HTMLElement>(".pano-edge--left")!,
	};

	const EDGE_ZONE = 100;
	const MAX_SPEED = 14;
	let panoRAF: number | null = null;
	let panoMouseX = window.innerWidth / 2;
	let panoMouseY = window.innerHeight / 2;

	function centerScroll() {
		panoScroll.scrollLeft =
			(panoCanvas.scrollWidth - panoScroll.clientWidth) / 2;
		panoScroll.scrollTop =
			(panoCanvas.scrollHeight - panoScroll.clientHeight) / 2;
	}

	function startEdgeScroll() {
		function tick() {
			const vw = window.innerWidth;
			const vh = window.innerHeight;
			let vx = 0,
				vy = 0;

			if (panoMouseX < EDGE_ZONE) {
				vx = -MAX_SPEED * Math.pow(1 - panoMouseX / EDGE_ZONE, 1.5);
			} else if (panoMouseX > vw - EDGE_ZONE) {
				vx = MAX_SPEED * Math.pow(1 - (vw - panoMouseX) / EDGE_ZONE, 1.5);
			}

			if (panoMouseY < EDGE_ZONE) {
				vy = -MAX_SPEED * Math.pow(1 - panoMouseY / EDGE_ZONE, 1.5);
			} else if (panoMouseY > vh - EDGE_ZONE) {
				vy = MAX_SPEED * Math.pow(1 - (vh - panoMouseY) / EDGE_ZONE, 1.5);
			}

			if (vx !== 0 || vy !== 0) {
				panoScroll.scrollLeft += vx;
				panoScroll.scrollTop += vy;
			}

			const canLeft = panoScroll.scrollLeft > 0;
			const canRight =
				panoScroll.scrollLeft <
				panoScroll.scrollWidth - panoScroll.clientWidth - 1;
			const canTop = panoScroll.scrollTop > 0;
			const canBottom =
				panoScroll.scrollTop <
				panoScroll.scrollHeight - panoScroll.clientHeight - 1;

			panoEdges.left.classList.toggle(
				"is-active",
				panoMouseX < EDGE_ZONE && canLeft,
			);
			panoEdges.right.classList.toggle(
				"is-active",
				panoMouseX > vw - EDGE_ZONE && canRight,
			);
			panoEdges.top.classList.toggle(
				"is-active",
				panoMouseY < EDGE_ZONE && canTop,
			);
			panoEdges.bottom.classList.toggle(
				"is-active",
				panoMouseY > vh - EDGE_ZONE && canBottom,
			);

			panoRAF = requestAnimationFrame(tick);
		}
		panoRAF = requestAnimationFrame(tick);
	}

	function stopEdgeScroll() {
		if (panoRAF !== null) {
			cancelAnimationFrame(panoRAF);
			panoRAF = null;
		}
		Object.values(panoEdges).forEach((el) => el.classList.remove("is-active"));
	}

	document.getElementById("home-pano")!.addEventListener("mousemove", (e) => {
		panoMouseX = e.clientX;
		panoMouseY = e.clientY;
	});

	// Init: center and start scrolling
	requestAnimationFrame(() => {
		centerScroll();
		startEdgeScroll();
	});

	// ── Lightbox ──
	const lightbox = document.getElementById("home-lightbox")!;
	const lbTitle = document.getElementById("home-lb-title")!;
	const lbCat = document.getElementById("home-lb-cat")!;
	const lbCounter = document.getElementById("home-lb-counter")!;
	const lbImage = document.getElementById("home-lb-image")!;
	const lbBack = document.getElementById("home-lb-back")!;
	const prevBtn = lightbox.querySelector<HTMLButtonElement>(
		".home-lb__arrow--prev",
	)!;
	const nextBtn = lightbox.querySelector<HTMLButtonElement>(
		".home-lb__arrow--next",
	)!;
	const tiles = Array.from(
		document.querySelectorAll<HTMLElement>(".pano-tile"),
	);

	let currentIndex = 0;

	function showImage(index: number) {
		const count = tiles.length;
		currentIndex = ((index % count) + count) % count;
		const tile = tiles[currentIndex];
		lbTitle.textContent = tile.dataset.title ?? "";
		lbCat.textContent = tile.dataset.cat ?? "";
		lbCounter.textContent = `${currentIndex + 1} / ${count}`;

		const placeholder = tile.querySelector<HTMLElement>(
			".pano-tile__placeholder",
		);
		if (placeholder) {
			const aspect = getComputedStyle(placeholder).aspectRatio;
			if (aspect && aspect !== "auto") {
				lbImage.style.aspectRatio = aspect;
			}
		}
	}

	function openLightbox(index: number) {
		showImage(index);
		stopEdgeScroll();
		lightbox.setAttribute("aria-hidden", "false");
		document.body.style.overflow = "hidden";
		lbBack.focus();
	}

	function closeLightbox() {
		lightbox.setAttribute("aria-hidden", "true");
		document.body.style.overflow = "";
		requestAnimationFrame(() => startEdgeScroll());
	}

	tiles.forEach((tile, i) => {
		const handler = () => openLightbox(i);
		tile.addEventListener("click", handler);
		tile.addEventListener("keydown", (e) => {
			if (e.key === "Enter" || e.key === " ") {
				e.preventDefault();
				handler();
			}
		});
	});

	prevBtn.addEventListener("click", () => showImage(currentIndex - 1));
	nextBtn.addEventListener("click", () => showImage(currentIndex + 1));
	lbBack.addEventListener("click", closeLightbox);

	lightbox.addEventListener("click", (e) => {
		if (e.target === lightbox) closeLightbox();
	});

	document.addEventListener("keydown", (e) => {
		if (lightbox.getAttribute("aria-hidden") !== "true") {
			if (e.key === "Escape") closeLightbox();
			if (e.key === "ArrowLeft") showImage(currentIndex - 1);
			if (e.key === "ArrowRight") showImage(currentIndex + 1);
		}
	});
</script>

<style>
	/* ═══ HOME PANORAMA (fullscreen gallery) ═══ */
	.home-pano {
		position: fixed;
		inset: 0;
		z-index: 1;
		background: linear-gradient(
			135deg,
			#0c1a2a 0%,
			#0a1520 30%,
			#162430 60%,
			#0d1a25 100%
		);
		animation: heroShift 20s ease-in-out infinite alternate;
	}

	@keyframes heroShift {
		0% {
			filter: brightness(0.9) hue-rotate(0deg);
		}
		100% {
			filter: brightness(1.1) hue-rotate(8deg);
		}
	}

	.home-pano__scroll {
		width: 100%;
		height: 100%;
		overflow: hidden;
		position: relative;
		z-index: 0;
	}

	@media (hover: none) {
		.home-pano__scroll {
			overflow: auto;
			-webkit-overflow-scrolling: touch;
		}
	}

	.home-pano__canvas {
		display: grid;
		grid-template-columns: repeat(6, clamp(240px, 25vw, 380px));
		grid-auto-rows: clamp(200px, 22vh, 350px);
		gap: 8px;
		padding: 2vh 1vw;
		grid-auto-flow: dense;
	}

	.home-pano__vignette {
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		background: radial-gradient(
			ellipse at center,
			transparent 40%,
			rgba(6, 6, 6, 0.5) 100%
		);
	}

	/* ── Logo ── */
	.home-pano__logo {
		position: absolute;
		bottom: var(--space-lg);
		right: var(--space-lg);
		z-index: 4;
		opacity: 0.4;
		transition: opacity 0.4s ease;
		display: block;
	}

	.home-pano__logo:hover {
		opacity: 0.85;
	}

	.home-pano__logo img {
		height: 28px;
		width: auto;
		display: block;
		filter: brightness(0.9);
	}

	/* ── Tiles ── */
	.pano-tile {
		position: relative;
		overflow: hidden;
		cursor: pointer;
		opacity: 0;
		transform: scale(0.92);
		animation: tileIn 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
	}

	@keyframes tileIn {
		to {
			opacity: 1;
			transform: scale(1);
		}
	}

	.pano-tile--tall {
		grid-row: span 2;
	}

	.pano-tile--wide {
		grid-column: span 2;
	}

	.pano-tile--lg {
		grid-column: span 2;
		grid-row: span 2;
	}

	.pano-tile__media {
		width: 100%;
		height: 100%;
		position: relative;
		overflow: hidden;
	}

	.pano-tile__placeholder {
		width: 100%;
		height: 100%;
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		display: flex;
		align-items: center;
		justify-content: center;
		transition:
			transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94),
			filter 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
		will-change: transform;
	}

	.pano-tile:hover .pano-tile__placeholder {
		transform: scale(1.06);
		filter: brightness(0.75);
	}

	.pano-tile__icon {
		font-size: var(--text-2xl);
		color: var(--color-text-dim);
		opacity: 0.3;
	}

	.pano-tile__overlay {
		position: absolute;
		inset: auto 0 0 0;
		padding: var(--space-lg) var(--space-sm) var(--space-xs);
		background: linear-gradient(
			to top,
			rgba(6, 6, 6, 0.85) 0%,
			transparent 100%
		);
		display: flex;
		flex-direction: column;
		gap: 0.2em;
		opacity: 0;
		transform: translateY(6px);
		transition:
			opacity 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
			transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
		pointer-events: none;
	}

	.pano-tile:hover .pano-tile__overlay {
		opacity: 1;
		transform: translateY(0);
	}

	.pano-tile__title {
		font-family: var(--font-display);
		font-size: var(--text-base);
		font-weight: 600;
		color: var(--color-text);
		line-height: 1.2;
	}

	.pano-tile__cat {
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-sunset);
	}

	/* ── Edge scroll indicators ── */
	.pano-edge {
		position: absolute;
		z-index: 3;
		pointer-events: none;
		opacity: 0;
		transition: opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.pano-edge.is-active {
		opacity: 1;
	}

	.pano-edge--top {
		inset: 0 0 auto 0;
		height: 100px;
		background: linear-gradient(
			to bottom,
			rgba(224, 178, 86, 0.06) 0%,
			transparent 100%
		);
	}

	.pano-edge--bottom {
		inset: auto 0 0 0;
		height: 100px;
		background: linear-gradient(
			to top,
			rgba(224, 178, 86, 0.06) 0%,
			transparent 100%
		);
	}

	.pano-edge--left {
		inset: 0 auto 0 0;
		width: 100px;
		background: linear-gradient(
			to right,
			rgba(224, 178, 86, 0.06) 0%,
			transparent 100%
		);
	}

	.pano-edge--right {
		inset: 0 0 0 auto;
		width: 100px;
		background: linear-gradient(
			to left,
			rgba(224, 178, 86, 0.06) 0%,
			transparent 100%
		);
	}

	/* ═══ LIGHTBOX ═══ */
	.home-lb {
		position: fixed;
		inset: 0;
		z-index: 9999;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(6, 6, 6, 0.96);
		backdrop-filter: blur(24px);
		-webkit-backdrop-filter: blur(24px);
		opacity: 1;
		visibility: visible;
		transition:
			opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1),
			visibility 0s linear 0s,
			backdrop-filter 0.6s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.home-lb[aria-hidden="true"] {
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		backdrop-filter: blur(0px);
		-webkit-backdrop-filter: blur(0px);
		transition:
			opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1),
			visibility 0s linear 0.4s,
			backdrop-filter 0.4s cubic-bezier(0.22, 1, 0.36, 1);
	}

	/* ── Header inside lightbox ── */
	.home-lb__header {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		z-index: 10;
		opacity: 1;
		transition:
			opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1) 0.15s,
			top 0.4s cubic-bezier(0.22, 1, 0.36, 1) 0.15s;
	}

	.home-lb[aria-hidden="true"] .home-lb__header {
		opacity: 0;
		top: -20px;
		transition-delay: 0s;
	}

	/* Force the header inside lightbox to always show with glass bg */
	.home-lb__header :global(.site-header) {
		background: rgba(10, 10, 10, 0.6);
		border-bottom: 1px solid rgba(255, 255, 255, 0.04);
		transform: none !important;
	}

	/* ── Back button ── */
	.home-lb__back {
		position: absolute;
		bottom: var(--space-lg);
		left: 50%;
		transform: translateX(-50%);
		z-index: 5;
		display: flex;
		align-items: center;
		gap: 0.5em;
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-dim);
		background: rgba(255, 255, 255, 0.04);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 100px;
		padding: 0.7em 1.6em;
		cursor: pointer;
		opacity: 1;
		transition:
			color 0.3s cubic-bezier(0.22, 1, 0.36, 1),
			background 0.3s cubic-bezier(0.22, 1, 0.36, 1),
			border-color 0.3s cubic-bezier(0.22, 1, 0.36, 1),
			opacity 0.35s cubic-bezier(0.22, 1, 0.36, 1) 0.2s;
	}

	.home-lb[aria-hidden="true"] .home-lb__back {
		opacity: 0;
		transition-delay: 0s;
	}

	.home-lb__back:hover {
		color: var(--color-text);
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.1);
	}

	.home-lb__back:focus-visible {
		outline: 2px solid var(--color-sunset);
		outline-offset: 2px;
	}

	/* ── Arrows ── */
	.home-lb__arrow {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		z-index: 5;
		color: var(--color-text-dim);
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid var(--color-border);
		width: 52px;
		height: 52px;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		opacity: 1;
		transition:
			color var(--duration-fast) var(--ease-out-quart),
			background var(--duration-fast) var(--ease-out-quart),
			border-color var(--duration-fast) var(--ease-out-quart),
			opacity 0.35s cubic-bezier(0.22, 1, 0.36, 1) 0.12s,
			transform 0.35s cubic-bezier(0.22, 1, 0.36, 1) 0.12s;
	}

	.home-lb[aria-hidden="true"] .home-lb__arrow {
		opacity: 0;
		transition-delay: 0s;
	}

	.home-lb[aria-hidden="true"] .home-lb__arrow--prev {
		transform: translateY(-50%) translateX(-12px);
	}

	.home-lb[aria-hidden="true"] .home-lb__arrow--next {
		transform: translateY(-50%) translateX(12px);
	}


---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
	title="Sergi Ortega — Fotografía deportiva & Vídeo comercial"
	description="Sergi Ortega, fotógrafo deportivo y videógrafo profesional. Especializado en surf, foto marina, deportes de acción y producciones audiovisuales comerciales. Desde El Palmar, Cádiz."
>
	<!-- ═══ MOSAIC HERO ═══ -->
	<section class="mosaic">
		<div class="mosaic__grid">
			<a href="/fotografia" class="mosaic__cell mosaic__cell--main">
				<div class="mosaic__img mosaic__img--1"></div>
				<div class="mosaic__caption">
					<span class="label">Surf & Mar</span>
				</div>
			</a>

			<a href="/fotografia" class="mosaic__cell mosaic__cell--tall">
				<div class="mosaic__img mosaic__img--2"></div>
				<div class="mosaic__caption">
					<span class="label">Retratos</span>
				</div>
			</a>

			<div class="mosaic__cell mosaic__cell--text">
				<div class="mosaic__rule"></div>
				<h1>
					Capturo la fuerza del deporte y&nbsp;la&nbsp;belleza del&nbsp;océano.
				</h1>
				<p>
					Fotografía, vídeo y producción audiovisual desde&nbsp;El&nbsp;Palmar.
				</p>
				<div class="mosaic__actions">
					<a href="/fotografia" class="cta-button cta-button--sm">Fotografía</a>
					<a href="/video" class="btn-outline cta-button--sm">Vídeo</a>
				</div>
			</div>

			<a href="/fotografia" class="mosaic__cell mosaic__cell--small1">
				<div class="mosaic__img mosaic__img--3"></div>
				<div class="mosaic__caption">
					<span class="label">Deportes</span>
				</div>
			</a>

			<a href="/fotografia" class="mosaic__cell mosaic__cell--wide">
				<div class="mosaic__img mosaic__img--4"></div>
				<div class="mosaic__caption">
					<span class="label">Surf & Mar</span>
				</div>
			</a>

			<a href="/fotografia" class="mosaic__cell mosaic__cell--small2">
				<div class="mosaic__img mosaic__img--5"></div>
				<div class="mosaic__caption">
					<span class="label">Eventos</span>
				</div>
			</a>
		</div>
	</section>

	<!-- ═══ CTA ═══ -->
	<section class="home-cta">
		<div class="home-cta__inner container reveal">
			<span class="label">Colaboremos</span>
			<h2 class="home-cta__heading">¿Tienes un <em>proyecto</em> en mente?</h2>
			<p class="home-cta__text">
				Sesiones de foto, vídeo comercial, videoclips o cobertura de eventos —
				hablemos.
			</p>
			<a href="/contacto" class="cta-button">Contactar</a>
		</div>
	</section>
</BaseLayout>

<style>
	/* ═══ MOSAIC HERO ═══ */
	.mosaic {
		min-height: 100dvh;
		padding: calc(80px + 6px) 6px 6px;
	}

	.mosaic__grid {
		display: grid;
		grid-template-columns: 1.3fr 1fr 1fr;
		grid-template-rows: 1.4fr 1fr 1fr;
		gap: 4px;
		height: calc(100dvh - 80px - 12px);
		max-width: 1600px;
		margin: 0 auto;
		grid-template-areas:
			"main main   tall"
			"text small1 tall"
			"wide wide   small2";
	}

	/* ── Cells ── */
	.mosaic__cell {
		position: relative;
		overflow: hidden;
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.mosaic__cell--main {
		grid-area: main;
	}
	.mosaic__cell--tall {
		grid-area: tall;
	}
	.mosaic__cell--text {
		grid-area: text;
	}
	.mosaic__cell--small1 {
		grid-area: small1;
	}
	.mosaic__cell--wide {
		grid-area: wide;
	}
	.mosaic__cell--small2 {
		grid-area: small2;
	}

	/* ── Staggered entrance ── */
	.mosaic__cell--main {
		animation: mosaicIn 0.9s var(--ease-out-expo) 0.05s backwards;
	}
	.mosaic__cell--tall {
		animation: mosaicIn 0.9s var(--ease-out-expo) 0.15s backwards;
	}
	.mosaic__cell--text {
		animation: mosaicIn 0.9s var(--ease-out-expo) 0.25s backwards;
	}
	.mosaic__cell--small1 {
		animation: mosaicIn 0.9s var(--ease-out-expo) 0.3s backwards;
	}
	.mosaic__cell--wide {
		animation: mosaicIn 0.9s var(--ease-out-expo) 0.38s backwards;
	}
	.mosaic__cell--small2 {
		animation: mosaicIn 0.9s var(--ease-out-expo) 0.45s backwards;
	}

	@keyframes mosaicIn {
		from {
			opacity: 0;
			transform: scale(0.96);
		}
	}

	/* ── Photo backgrounds (placeholders) ── */
	.mosaic__img {
		position: absolute;
		inset: 0;
		transition:
			transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
			filter 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	.mosaic__cell:hover .mosaic__img {
		transform: scale(1.05);
		filter: brightness(0.65);
	}

	.mosaic__img--1 {
		background: linear-gradient(
			135deg,
			#0a1e30 0%,
			#1b6b93 35%,
			#0d2535 70%,
			#060e18 100%
		);
	}

	.mosaic__img--2 {
		background: linear-gradient(
			170deg,
			#1a1510 0%,
			#2d2418 45%,
			#1a150d 75%,
			#0e0c08 100%
		);
	}

	.mosaic__img--3 {
		background: linear-gradient(145deg, #101c25 0%, #1a3448 50%, #0c1820 100%);
	}

	.mosaic__img--4 {
		background: linear-gradient(
			120deg,
			#091420 0%,
			#155070 40%,
			#0e2a40 75%,
			#060e18 100%
		);
	}

	.mosaic__img--5 {
		background: linear-gradient(155deg, #1e1610 0%, #2a2015 45%, #14100a 100%);
	}

	/* ── Photo captions (on hover) ── */
	.mosaic__caption {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: var(--space-xl) var(--space-sm) var(--space-sm);
		background: linear-gradient(
			to top,
			rgba(6, 6, 6, 0.85) 0%,
			transparent 100%
		);
		opacity: 0;
		transform: translateY(6px);
		transition:
			opacity 0.4s ease,
			transform 0.4s ease;
		z-index: 1;
	}

	.mosaic__cell:hover .mosaic__caption {
		opacity: 1;
		transform: translateY(0);
	}

	.mosaic__caption .label {
		color: var(--color-sunset);
	}

	/* ── Text cell ── */
	.mosaic__cell--text {
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: var(--space-md);
		background:
			radial-gradient(
				ellipse at 20% 80%,
				rgba(27, 107, 147, 0.1) 0%,
				transparent 60%
			),
			var(--color-bg);
		border: 1px solid var(--color-border);
	}

	.mosaic__rule {
		width: 32px;
		height: 2px;
		background: var(--color-sunset);
		margin-bottom: var(--space-sm);
	}

	.mosaic__cell--text h1 {
		font-family: var(--font-display);
		font-size: clamp(1.15rem, 0.8rem + 1.3vw, 1.85rem);
		font-weight: 700;
		line-height: 1.25;
		letter-spacing: -0.02em;
		color: var(--color-text);
		margin-bottom: var(--space-xs);
	}

	.mosaic__cell--text p {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		line-height: 1.45;
		margin-bottom: var(--space-sm);
	}

	.mosaic__actions {
		display: flex;
		gap: var(--space-xs);
	}

	.cta-button--sm {
		font-size: clamp(0.6rem, 0.55rem + 0.2vw, 0.72rem);
		padding: 0.7em 1.4em;
		letter-spacing: 0.1em;
	}

	/* ═══ CTA ═══ */
	.home-cta {
		padding-block: var(--space-section);
		border-top: 1px solid var(--color-border);
	}

	.home-cta__inner {
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-sm);
	}

	.home-cta__heading {
		margin-top: var(--space-xs);
	}

	.home-cta__text {
		color: var(--color-text-muted);
		text-align: center;
		max-width: 50ch;
	}

	/* ═══ RESPONSIVE ═══ */
	@media (max-width: 1024px) {
		.mosaic {
			min-height: auto;
			padding: calc(70px + 5px) 5px 5px;
		}

		.mosaic__grid {
			height: auto;
			grid-template-columns: 1fr 1fr;
			grid-template-rows: 260px auto 200px 220px;
			grid-template-areas:
				"main  main"
				"text  tall"
				"small1 tall"
				"wide  small2";
		}
	}

	@media (max-width: 640px) {
		.mosaic {
			padding: calc(64px + 4px) 4px 4px;
		}

		.mosaic__grid {
			grid-template-columns: 1fr 1fr;
			grid-template-rows: 200px auto 180px 180px;
			gap: 3px;
			grid-template-areas:
				"main  main"
				"text  text"
				"tall  small1"
				"wide  small2";
		}

		.mosaic__cell--text {
			padding: var(--space-sm) var(--space-md);
		}

		.mosaic__cell--text h1 {
			font-size: clamp(1.1rem, 0.9rem + 1vw, 1.4rem);
		}
	}

	@media (max-width: 380px) {
		.mosaic__actions {
			flex-direction: column;
		}

		.cta-button--sm {
			text-align: center;
		}
	}
</style>

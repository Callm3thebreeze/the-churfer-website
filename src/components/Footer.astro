---
const year = new Date().getFullYear();

const socialLinks = [
  { href: "#", label: "Instagram", icon: "IG" },
  { href: "#", label: "YouTube", icon: "YT" },
];
---

<footer class="site-footer">
  <div class="site-footer__inner container">
    <div class="site-footer__top">
      <a href="/" class="site-footer__logo">The Churfer</a>

      <nav class="site-footer__social" aria-label="Redes sociales">
        {
          socialLinks.map(({ href, label, icon }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={label}
              class="site-footer__social-link"
            >
              {icon}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="site-footer__divider"></div>

    <div class="site-footer__bottom">
      <p class="site-footer__copy">&copy; {year} The Churfer — Sergi Ortega</p>
      <p class="site-footer__location">Mediterranean Coast</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-section);
    padding-block: var(--space-xl) var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .site-footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .site-footer__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .site-footer__logo {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--color-text);
    letter-spacing: -0.01em;
    transition: opacity var(--duration-fast) var(--ease-out-quart);
  }

  .site-footer__logo:hover {
    opacity: 0.6;
  }

  .site-footer__social {
    display: flex;
    gap: 1.2em;
  }

  .site-footer__social-link {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-text-dim);
    padding: 0.5em;
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .site-footer__social-link:hover {
    color: var(--color-sunset);
  }

  .site-footer__divider {
    height: 1px;
    background: var(--color-border);
  }

  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5em;
  }

  .site-footer__copy,
  .site-footer__location {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    letter-spacing: 0.03em;
  }

  .site-footer__location {
    font-style: italic;
    font-family: var(--font-display);
    letter-spacing: 0;
  }
</style>

---
import { buildImageUrl, buildSrcSet } from "../lib/cloudinary";

interface Props {
  publicId: string;
  alt: string;
  width?: number;
  height?: number;
  sizes?: string;
  class?: string;
  loading?: "lazy" | "eager";
}

const {
  publicId,
  alt,
  width,
  height,
  sizes = "(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw",
  class: className,
  loading = "lazy",
} = Astro.props;

const src = buildImageUrl(publicId, { width, height, crop: "fill" });
const srcset = buildSrcSet(publicId);
---

<img
  src={src}
  srcset={srcset}
  sizes={sizes}
  alt={alt}
  width={width}
  height={height}
  class={className}
  loading={loading}
  decoding="async"
/>

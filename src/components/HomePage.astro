---
import { Image as AstroImage, getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getGalleryData } from "../lib/photo-gallery";
import { getVideoLibrary, formatDate, getCategoryLabel } from "../lib/videos";

const { photos } = await getGalleryData();
const { videos } = await getVideoLibrary();

const surfPhotos = photos.filter(
  (photo) => photo.category === "surf" || photo.tags.includes("surf"),
);
const featuredPhotos = await Promise.all(
  (surfPhotos.length > 0 ? surfPhotos : photos)
    .slice(0, 20)
    .map(async (photo) => {
      if (!photo.image) {
        return {
          ...photo,
          lightboxSrc: photo.src,
        };
      }

      const lightboxImage = await getImage({
        src: photo.image,
        width: 2200,
        format: "webp",
        quality: 74,
      });

      return {
        ...photo,
        lightboxSrc: lightboxImage.src,
      };
    }),
);

const featuredVideos = videos.slice(0, 3);
---

<BaseLayout
  title="Fotógrafo de Surf en Cádiz con mirada acuática"
  description="Fotografía de surf, mar y deporte desde El Palmar, Cádiz. The Churfer une mirada documental, energía visual y sensibilidad cinematográfica para marcas, atletas y proyectos editoriales."
>
  <section class="home-hero page-hero">
    <div class="home-hero__inner page-hero__inner container">
      <div class="home-hero__copy">
        <h1 class="reveal">Fotografía de surf en Cádiz</h1>
        <p class="home-hero__desc page-hero__desc reveal">
          Fotografía y vídeo desde El Palmar, Cádiz. Surf, agua, deporte y
          colaboraciones comerciales.
        </p>

        <div class="home-hero__actions reveal">
          <a href="/fotografia" class="cta-button">Fotografía</a>
          <a href="/video" class="btn-outline">Vídeo</a>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section home-section--photos container">
    <div class="home-section__top reveal is-visible">
      <div>
        <span class="label">Fotografía</span>
        <h2>Surf, cámara y acción</h2>
      </div>

      <div class="home-section__actions">
        <a href="/fotografia" class="btn-outline">Fotografía</a>
      </div>
    </div>

    <div
      class="home-photo-carousel reveal is-visible"
      data-photo-carousel
      role="region"
      aria-roledescription="carrusel"
      aria-label={`Carrusel con ${featuredPhotos.length} fotografías de surf`}
    >
      <div class="home-photo-carousel__viewport" data-photo-carousel-viewport>
        <div class="home-photo-carousel__track" data-photo-carousel-track>
          {
            featuredPhotos.map((photo, index) => (
              <button
                type="button"
                class={`home-photo-carousel__slide reveal-delay-${(index % 4) + 1}`}
                aria-label={
                  photo.title
                    ? `Abrir galeria: ${photo.title}`
                    : "Abrir galeria"
                }
                aria-haspopup="dialog"
                data-home-lightbox-item
                data-src={photo.lightboxSrc}
                data-alt={photo.alt}
                data-title={photo.title}
                data-cat={photo.displayCategory}
                data-aspect={photo.aspect}
              >
                <div class="home-photo-carousel__media">
                  {photo.image ? (
                    <AstroImage
                      src={photo.image}
                      alt={photo.alt}
                      class="home-photo-carousel__image"
                      loading="lazy"
                      format="webp"
                      quality={72}
                      sizes="(max-width: 768px) 78vw, (max-width: 1100px) 34vw, 22vw"
                      widths={[520, 920, 1360]}
                    />
                  ) : (
                    <img
                      src={photo.src}
                      alt={photo.alt}
                      class="home-photo-carousel__image"
                      loading="lazy"
                      decoding="async"
                      width={photo.width}
                      height={photo.height}
                    />
                  )}
                </div>
              </button>
            ))
          }
        </div>
      </div>

      <div
        class="home-photo-carousel__status sr-only"
        aria-live="polite"
        data-carousel-status
      >
        Fotografía 1 de {featuredPhotos.length}
      </div>

      <div class="home-photo-carousel__footer">
        <div
          class="home-photo-carousel__controls"
          aria-label="Controles del carrusel"
        >
          <button
            class="home-photo-carousel__button"
            type="button"
            aria-label="Ver fotografías anteriores"
            data-carousel-prev
          >
            <span aria-hidden="true">&larr;</span>
          </button>

          <div
            class="home-photo-carousel__pagination"
            aria-label={`Indicadores del carrusel, ${featuredPhotos.length} fotografías`}
            role="tablist"
          >
            {
              featuredPhotos.map((photo, index) => (
                <button
                  class="home-photo-carousel__dot"
                  type="button"
                  role="tab"
                  aria-label={
                    photo.title
                      ? `Ir a la fotografia ${index + 1} de ${featuredPhotos.length}: ${photo.title}`
                      : `Ir a la fotografia ${index + 1} de ${featuredPhotos.length}`
                  }
                  aria-selected={index === 0 ? "true" : "false"}
                  aria-current={index === 0 ? "true" : "false"}
                  data-carousel-dot
                  data-carousel-index={index}
                >
                  <span class="sr-only">Fotografía {index + 1}</span>
                </button>
              ))
            }
          </div>

          <button
            class="home-photo-carousel__button"
            type="button"
            aria-label="Ver fotografías siguientes"
            data-carousel-next
          >
            <span aria-hidden="true">&rarr;</span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <div
    class="lightbox"
    id="home-lightbox"
    aria-hidden="true"
    role="dialog"
    aria-label="Galería ampliada"
  >
    <button class="lightbox__close" type="button" aria-label="Cerrar galería">
      <svg
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>
    <button
      class="lightbox__arrow lightbox__arrow--prev"
      type="button"
      aria-label="Imagen anterior"
    >
      <svg
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path d="M15 18l-6-6 6-6"></path>
      </svg>
    </button>
    <button
      class="lightbox__arrow lightbox__arrow--next"
      type="button"
      aria-label="Imagen siguiente"
    >
      <svg
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path d="M9 18l6-6-6-6"></path>
      </svg>
    </button>
    <div class="lightbox__content">
      <img
        class="lightbox__placeholder is-ready"
        id="home-lightbox-image"
        src={featuredPhotos[0]?.lightboxSrc ?? ""}
        alt="Imagen ampliada"
        loading="eager"
        decoding="async"
      />
      <div class="lightbox__info">
        <h3 class="lightbox__title" id="home-lightbox-title"></h3>
        <span class="lightbox__cat label" id="home-lightbox-cat"></span>
        <span class="lightbox__counter" id="home-lightbox-counter"></span>
      </div>
    </div>
  </div>

  <section class="home-section container">
    <div class="home-section__top reveal is-visible">
      <div>
        <span class="label">Vídeo</span>
        <h2>Trabajos en vídeo</h2>
      </div>

      <a href="/video" class="btn-outline">Vídeo</a>
    </div>

    <div class="home-video-grid">
      {
        featuredVideos.map((video, index) => (
          <article
            class={`home-video-card reveal is-visible reveal-delay-${(index % 3) + 1}`}
          >
            <a href={`/video/${video.slug}`} class="home-video-card__media">
              <img
                src={`https://i.ytimg.com/vi/${video.youtubeId}/hqdefault.jpg`}
                alt={video.title}
                loading="lazy"
                decoding="async"
                width="640"
                height="360"
              />
            </a>

            <div class="home-video-card__body">
              <div class="home-video-card__meta">
                <span class="label">{getCategoryLabel(video.category)}</span>
                <time datetime={video.date}>{formatDate(video.date)}</time>
              </div>

              <h3>{video.title}</h3>
              <p>{video.description}</p>
              <a href={`/video/${video.slug}`} class="home-video-card__link">
                Ver proyecto
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<script>
  const photoCarousel = document.querySelector("[data-photo-carousel]");
  const photoCarouselSection = document.querySelector(".home-section--photos");
  const homeLightbox = document.getElementById("home-lightbox");
  const homeLightboxItems = Array.from(
    document.querySelectorAll("[data-home-lightbox-item]"),
  );

  if (photoCarousel instanceof HTMLElement) {
    const viewport = photoCarousel.querySelector(
      "[data-photo-carousel-viewport]",
    );
    const track = photoCarousel.querySelector("[data-photo-carousel-track]");
    const prevButton = photoCarouselSection?.querySelector(
      "[data-carousel-prev]",
    );
    const nextButton = photoCarouselSection?.querySelector(
      "[data-carousel-next]",
    );
    const status = photoCarousel.querySelector("[data-carousel-status]");
    const dots = Array.from(
      photoCarousel.querySelectorAll("[data-carousel-dot]"),
    );

    if (
      viewport instanceof HTMLElement &&
      track instanceof HTMLElement &&
      prevButton instanceof HTMLButtonElement &&
      nextButton instanceof HTMLButtonElement &&
      status instanceof HTMLElement
    ) {
      let activeIndex = 0;

      const getStep = () => {
        const firstSlide = track.querySelector(".home-photo-carousel__slide");

        if (!(firstSlide instanceof HTMLElement)) {
          return viewport.clientWidth * 0.8;
        }

        const trackStyles = getComputedStyle(track);
        const gap = Number.parseFloat(
          trackStyles.columnGap || trackStyles.gap || "0",
        );
        return firstSlide.getBoundingClientRect().width + gap;
      };

      const getActiveIndex = () => {
        const step = getStep();

        if (!Number.isFinite(step) || step <= 0) {
          return 0;
        }

        return Math.max(
          0,
          Math.min(dots.length - 1, Math.round(viewport.scrollLeft / step)),
        );
      };

      const updateDots = () => {
        activeIndex = getActiveIndex();

        dots.forEach((dot, index) => {
          if (!(dot instanceof HTMLButtonElement)) {
            return;
          }

          const isActive = index === activeIndex;
          dot.dataset.active = isActive ? "true" : "false";
          dot.setAttribute("aria-selected", isActive ? "true" : "false");
          dot.setAttribute("aria-current", isActive ? "true" : "false");
        });

        status.textContent = `Fotografía ${activeIndex + 1} de ${dots.length}`;
      };

      const updateButtons = () => {
        const maxScrollLeft = viewport.scrollWidth - viewport.clientWidth - 2;
        const hasOverflow = viewport.scrollWidth > viewport.clientWidth + 2;

        prevButton.disabled = !hasOverflow || viewport.scrollLeft <= 2;
        nextButton.disabled =
          !hasOverflow || viewport.scrollLeft >= maxScrollLeft;
      };

      prevButton.addEventListener("click", () => {
        viewport.scrollTo({
          left: getStep() * Math.max(0, activeIndex - 1),
          behavior: "smooth",
        });
      });

      nextButton.addEventListener("click", () => {
        viewport.scrollTo({
          left: getStep() * Math.min(dots.length - 1, activeIndex + 1),
          behavior: "smooth",
        });
      });

      dots.forEach((dot, index) => {
        if (!(dot instanceof HTMLButtonElement)) {
          return;
        }

        dot.addEventListener("click", () => {
          viewport.scrollTo({
            left: getStep() * index,
            behavior: "smooth",
          });
          dot.focus({ preventScroll: true });
        });
      });

      viewport.addEventListener(
        "scroll",
        () => {
          updateButtons();
          updateDots();
        },
        { passive: true },
      );
      window.addEventListener("resize", () => {
        updateButtons();
        updateDots();
      });
      updateButtons();
      updateDots();
    }
  }

  if (homeLightbox instanceof HTMLElement && homeLightboxItems.length > 0) {
    const lightboxImage = document.getElementById("home-lightbox-image");
    const lightboxTitle = document.getElementById("home-lightbox-title");
    const lightboxCat = document.getElementById("home-lightbox-cat");
    const lightboxCounter = document.getElementById("home-lightbox-counter");
    const closeButton = homeLightbox.querySelector(".lightbox__close");
    const prevArrow = homeLightbox.querySelector(".lightbox__arrow--prev");
    const nextArrow = homeLightbox.querySelector(".lightbox__arrow--next");

    if (
      lightboxImage instanceof HTMLImageElement &&
      lightboxTitle instanceof HTMLElement &&
      lightboxCat instanceof HTMLElement &&
      lightboxCounter instanceof HTMLElement &&
      closeButton instanceof HTMLButtonElement &&
      prevArrow instanceof HTMLButtonElement &&
      nextArrow instanceof HTMLButtonElement
    ) {
      let currentLightboxIndex = 0;
      let lightboxImageToken = 0;

      const syncScrollLock = () => {
        document.body.style.overflow =
          homeLightbox.getAttribute("aria-hidden") !== "true" ? "hidden" : "";
      };

      const swapLightboxImage = (
        src = "",
        alt = "Imagen ampliada",
        aspect = "",
      ) =>
        new Promise((resolve) => {
          const currentSrc = lightboxImage.getAttribute("src") ?? "";

          if (currentSrc === src) {
            lightboxImage.alt = alt;
            if (aspect) {
              lightboxImage.style.aspectRatio = aspect;
            }
            lightboxImage.classList.add("is-ready");
            resolve(undefined);
            return;
          }

          const token = ++lightboxImageToken;
          lightboxImage.classList.remove("is-ready");
          if (aspect) {
            lightboxImage.style.aspectRatio = aspect;
          }

          const preloaded = new window.Image();
          preloaded.decoding = "async";
          preloaded.src = src;

          const applyImage = () => {
            if (token !== lightboxImageToken) {
              resolve(undefined);
              return;
            }

            lightboxImage.src = src;
            lightboxImage.alt = alt;
            requestAnimationFrame(() => {
              lightboxImage.classList.add("is-ready");
              resolve(undefined);
            });
          };

          preloaded.addEventListener("load", applyImage, { once: true });
          preloaded.addEventListener("error", applyImage, { once: true });
        });

      const showLightboxImage = async (index = 0) => {
        currentLightboxIndex =
          ((index % homeLightboxItems.length) + homeLightboxItems.length) %
          homeLightboxItems.length;

        const item = homeLightboxItems[currentLightboxIndex];
        if (!(item instanceof HTMLElement)) {
          return;
        }

        lightboxTitle.textContent = item.dataset.title ?? "";
        lightboxCat.textContent = item.dataset.cat ?? "";
        lightboxCounter.textContent = `${currentLightboxIndex + 1} / ${homeLightboxItems.length}`;

        await swapLightboxImage(
          item.dataset.src ?? "",
          item.dataset.alt ?? "Imagen ampliada",
          item.dataset.aspect,
        );
      };

      const openLightbox = async (index = 0) => {
        homeLightbox.setAttribute("aria-hidden", "false");
        syncScrollLock();
        lightboxImage.classList.remove("is-ready");
        lightboxImage.removeAttribute("src");
        await showLightboxImage(index);

        if (homeLightbox.getAttribute("aria-hidden") === "true") {
          return;
        }

        closeButton.focus();
      };

      const closeLightbox = () => {
        lightboxImageToken += 1;
        homeLightbox.setAttribute("aria-hidden", "true");
        syncScrollLock();
      };

      homeLightboxItems.forEach((item, index) => {
        if (!(item instanceof HTMLButtonElement)) {
          return;
        }

        item.addEventListener("click", () => {
          void openLightbox(index);
        });
      });

      prevArrow.addEventListener("click", () => {
        void showLightboxImage(currentLightboxIndex - 1);
      });
      nextArrow.addEventListener("click", () => {
        void showLightboxImage(currentLightboxIndex + 1);
      });
      closeButton.addEventListener("click", closeLightbox);

      homeLightbox.addEventListener("click", (event) => {
        if (event.target === homeLightbox) {
          closeLightbox();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (homeLightbox.getAttribute("aria-hidden") === "true") {
          return;
        }

        if (event.key === "Escape") {
          closeLightbox();
        }
        if (event.key === "ArrowLeft") {
          void showLightboxImage(currentLightboxIndex - 1);
        }
        if (event.key === "ArrowRight") {
          void showLightboxImage(currentLightboxIndex + 1);
        }
      });
    }
  }
</script>

<style>
  .home-hero__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .home-hero__desc {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    max-width: 58ch;
  }

  .home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  .home-section {
    padding-bottom: var(--space-section);
  }

  .home-section__top {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .home-section__top h2 {
    margin-top: 0.35rem;
  }

  .home-section__actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .home-photo-carousel {
    position: relative;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .home-photo-carousel__status {
    top: 0;
    left: 0;
  }

  .home-photo-carousel__footer {
    display: flex;
    justify-content: center;
    margin-top: var(--space-md);
  }

  .home-photo-carousel__viewport {
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
    padding-bottom: 0.2rem;
  }

  .home-photo-carousel__viewport::-webkit-scrollbar {
    display: none;
  }

  .home-photo-carousel__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: clamp(210px, 22vw, 290px);
    gap: 0.18rem;
  }

  .home-photo-carousel__slide {
    scroll-snap-align: start;
    scroll-snap-stop: always;
    display: flex;
    flex-direction: column;
    padding: 0;
    border: 0;
    background: none;
    text-align: left;
    cursor: zoom-in;
  }

  .home-photo-carousel__slide:focus-visible .home-photo-carousel__media {
    outline: 2px solid var(--color-ocean);
    outline-offset: 3px;
  }

  .home-photo-carousel__media {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.05);
    background: var(--color-bg-raised);
  }

  .home-photo-carousel__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 5;
    transition:
      transform var(--duration-slow) var(--ease-out-expo),
      opacity var(--duration-base) var(--ease-out-expo);
  }

  .home-photo-carousel__slide:hover .home-photo-carousel__image {
    transform: scale(1.015);
  }

  .home-photo-carousel__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: fit-content;
    max-width: 100%;
    flex-wrap: wrap;
  }

  .home-photo-carousel__button {
    width: 2.6rem;
    height: 2.6rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    color: var(--color-text-muted);
    transition:
      color var(--duration-fast) var(--ease-out-quart),
      border-color var(--duration-fast) var(--ease-out-quart),
      background var(--duration-fast) var(--ease-out-quart);
  }

  .home-photo-carousel__button:hover:not(:disabled) {
    color: var(--color-text);
    border-color: rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.05);
  }

  .home-photo-carousel__button:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .home-photo-carousel__pagination {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.45rem;
    max-width: min(100%, 480px);
  }

  .home-photo-carousel__dot {
    width: 0.55rem;
    height: 0.55rem;
    padding: 0;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.16);
    transition:
      transform var(--duration-fast) var(--ease-out-quart),
      background var(--duration-fast) var(--ease-out-quart),
      border-color var(--duration-fast) var(--ease-out-quart);
  }

  .home-photo-carousel__dot[data-active="true"] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    transform: scale(1.15);
  }

  .home-photo-carousel__dot:hover,
  .home-photo-carousel__dot:focus-visible {
    border-color: rgba(255, 255, 255, 0.52);
    background: rgba(255, 255, 255, 0.4);
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(6, 6, 6, 0.94);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    opacity: 1;
    visibility: visible;
    transition:
      opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 0s,
      backdrop-filter 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .lightbox[aria-hidden="true"] {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    transition:
      opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 0.4s,
      backdrop-filter 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .lightbox__close {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    color: var(--color-text-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5em;
    z-index: 2;
    opacity: 1;
    transition:
      color var(--duration-fast) var(--ease-out-quart),
      opacity 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 0.18s;
  }

  .lightbox[aria-hidden="true"] .lightbox__close {
    opacity: 0;
    transition-delay: 0s;
  }

  .lightbox__close:hover {
    color: var(--color-text);
  }

  .lightbox__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    color: var(--color-text-dim);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-border);
    width: 52px;
    height: 52px;
    display: flex;

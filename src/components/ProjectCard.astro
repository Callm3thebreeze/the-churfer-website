---
/**
 * Componente para mostrar una tarjeta de proyecto en el portfolio.
 * Muestra imagen de portada, título y categoría.
 */
interface Props {
  slug: string;
  title: string;
  category: string;
  coverImage: string;
}

const { slug, title, category, coverImage } = Astro.props;
---

<article>
  <a href={`/portfolio/${slug}`}>
    <img
      src={coverImage}
      alt={title}
      width={600}
      height={400}
      loading="lazy"
      decoding="async"
    />
    <h3>{title}</h3>
    <span>{category}</span>
  </a>
</article>

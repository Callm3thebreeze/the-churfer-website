---
import { Image as AstroImage, getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPanoramaTileClass } from "../data/photos";
import { getGalleryData } from "../lib/photo-gallery";

interface Props {
  canonicalPath?: string;
  noindex?: boolean;
}

const { canonicalPath, noindex = false } = Astro.props;

const HOME_GALLERY_CATEGORIES = new Set([
  "surf",
  "mar",
  "lugares",
  "naturaleza",
  "skate",
]);

const { photos: basePhotos, filters: categories } = await getGalleryData();
const photos = await Promise.all(
  basePhotos.map(async (photo) => {
    if (!photo.image) {
      return {
        ...photo,
        lightboxSrc: photo.src,
      };
    }

    const lightboxImage = await getImage({
      src: photo.image,
      width: 2200,
      format: "webp",
      quality: 74,
    });

    return {
      ...photo,
      lightboxSrc: lightboxImage.src,
    };
  }),
);
const panoramaPhotos = photos.filter((photo) =>
  photo.tags.some((tag) => HOME_GALLERY_CATEGORIES.has(tag)),
);
const panoramaTileClasses = panoramaPhotos.map((photo, i) =>
  getPanoramaTileClass(photo, i),
);
---

<BaseLayout
  title="Fotografía"
  description="Portfolio de fotografía deportiva de Sergi Ortega — The Churfer. Surf, foto marina, jiu-jitsu, skate y más. Desde El Palmar, Cádiz."
  canonicalPath={canonicalPath}
  noindex={noindex}
>
  <!-- ═══ PAGE HERO ═══ -->
  <section class="page-hero">
    <div class="page-hero__inner container">
      <h1 class="reveal">Fotografía</h1>
      <p class="page-hero__desc reveal">
        Surf, foto marina, jiu-jitsu, skate — capturo deportes de acción con la
        intensidad que merecen. Dentro del agua, al borde del tatami o en el
        bowl, mi cámara está donde pasa la acción.
      </p>
      <div class="rule reveal"></div>
    </div>
  </section>

  <section class="hero-gradient-lab-shell container reveal">
    <div class="hero-gradient-lab">
      <div class="hero-gradient-lab__intro">
        <span class="label">Gradient Lab</span>
        <p>
          Abre el panel, prueba tonos más verdosos y pásame un pantallazo con
          los valores que más te convenzan.
        </p>
      </div>
      <button
        class="hero-gradient-lab__toggle pill-btn"
        id="gradient-lab-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="gradient-lab-panel"
      >
        Ajustar degradado
      </button>
    </div>
    <section
      class="hero-gradient-panel"
      id="gradient-lab-panel"
      aria-label="Editor visual del degradado del hero"
      hidden
    >
      <div class="hero-gradient-panel__top">
        <div>
          <span class="label">Preview en vivo</span>
          <h2>Control del hero</h2>
        </div>
        <div class="hero-gradient-panel__actions">
          <button
            class="hero-gradient-panel__action"
            id="gradient-lab-reset"
            type="button"
          >
            Reset
          </button>
        </div>
      </div>

      <div class="hero-gradient-panel__preview" aria-hidden="true"></div>

      <div class="hero-gradient-panel__grid">
        <div class="hero-gradient-panel__group">
          <span class="label">Colores</span>

          <label class="gradient-control">
            <span class="gradient-control__meta">
              <span class="gradient-control__name">--color-hero-1</span>
              <span
                class="gradient-control__value"
                data-gradient-value-for="--color-hero-1"></span>
            </span>
            <input
              class="gradient-control__picker"
              type="color"
              value="#0c1a2a"
              data-gradient-control
              data-var="--color-hero-1"
            />
          </label>

          <label class="gradient-control">
            <span class="gradient-control__meta">
              <span class="gradient-control__name">--color-hero-2</span>
              <span
                class="gradient-control__value"
                data-gradient-value-for="--color-hero-2"></span>
            </span>
            <input
              class="gradient-control__picker"
              type="color"
              value="#0a1520"
              data-gradient-control
              data-var="--color-hero-2"
            />
          </label>

          <label class="gradient-control">
            <span class="gradient-control__meta">
              <span class="gradient-control__name">--color-hero-3</span>
              <span
                class="gradient-control__value"
                data-gradient-value-for="--color-hero-3"></span>
            </span>
            <input
              class="gradient-control__picker"
              type="color"
              value="#043966"
              data-gradient-control
              data-var="--color-hero-3"
            />
          </label>

          <label class="gradient-control">
            <span class="gradient-control__meta">
              <span class="gradient-control__name">--color-hero-4</span>
              <span
                class="gradient-control__value"
                data-gradient-value-for="--color-hero-4"></span>
            </span>
            <input
              class="gradient-control__picker"
              type="color"
              value="#0d1a25"
              data-gradient-control
              data-var="--color-hero-4"
            />
          </label>
        </div>

        <div class="hero-gradient-panel__group">
          <span class="label">Dirección y stops</span>

          <label class="gradient-slider">
            <span class="gradient-slider__meta">
              <span class="gradient-slider__name">Ángulo</span>
              <span
                class="gradient-slider__value"
                data-gradient-value-for="--hero-gradient-angle"
              >
              </span>
            </span>
            <input
              type="range"
              min="0"
              max="360"
              step="1"
              value="135"
              data-gradient-control
              data-var="--hero-gradient-angle"
              data-unit="deg"
            />
          </label>

          <label class="gradient-slider">
            <span class="gradient-slider__meta">
              <span class="gradient-slider__name">Stop 1</span>
              <span
                class="gradient-slider__value"
                data-gradient-value-for="--hero-stop-1"
              >
              </span>
            </span>
            <input
              type="range"
              min="0"
              max="100"
              step="1"
              value="0"
              data-gradient-control
              data-var="--hero-stop-1"
              data-unit="%"
            />
          </label>

          <label class="gradient-slider">
            <span class="gradient-slider__meta">
              <span class="gradient-slider__name">Stop 2</span>
              <span
                class="gradient-slider__value"
                data-gradient-value-for="--hero-stop-2"
              >
              </span>
            </span>
            <input
              type="range"
              min="0"
              max="100"
              step="1"
              value="30"
              data-gradient-control
              data-var="--hero-stop-2"
              data-unit="%"
            />
          </label>

          <label class="gradient-slider">
            <span class="gradient-slider__meta">
              <span class="gradient-slider__name">Stop 3</span>
              <span
                class="gradient-slider__value"
                data-gradient-value-for="--hero-stop-3"
              >
              </span>
            </span>
            <input
              type="range"
              min="0"
              max="100"
              step="1"
              value="60"
              data-gradient-control
              data-var="--hero-stop-3"
              data-unit="%"
            />
          </label>

          <label class="gradient-slider">
            <span class="gradient-slider__meta">
              <span class="gradient-slider__name">Stop 4</span>
              <span
                class="gradient-slider__value"
                data-gradient-value-for="--hero-stop-4"
              >
              </span>
            </span>
            <input
              type="range"
              min="0"
              max="100"
              step="1"
              value="100"
              data-gradient-control
              data-var="--hero-stop-4"
              data-unit="%"
            />
          </label>
        </div>
      </div>

      <div class="hero-gradient-panel__code">
        <span class="label">Valores para captura</span>
        <pre id="gradient-css-output"></pre>
      </div>
    </section>
  </section>

  <!-- ═══ TOOLBAR ═══ -->
  <div class="gallery-toolbar container reveal">
    <nav class="filters" aria-label="Filtrar por categoría">
      {
        categories.map(({ id, label }) => (
          <button
            class="filters__btn pill-btn"
            data-filter={id}
            aria-pressed={id === "all" ? "true" : "false"}
          >
            {label}
          </button>
        ))
      }
    </nav>
    <button class="panorama-trigger pill-btn" id="panorama-open" type="button">
      <svg
        width="16"
        height="16"
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.4"
      >
        <rect x="1" y="1" width="5.5" height="5.5" rx="0.5"></rect>
        <rect x="9.5" y="1" width="5.5" height="5.5" rx="0.5"></rect>
        <rect x="1" y="9.5" width="5.5" height="5.5" rx="0.5"></rect>
        <rect x="9.5" y="9.5" width="5.5" height="5.5" rx="0.5"></rect>
      </svg>
      Vista global
    </button>
  </div>

  <!-- ═══ GALLERY ═══ -->
  <section class="gallery container">
    <div class="gallery__grid">
      {
        photos.map((photo, i) => (
          <article
            class={`gallery__item reveal reveal-delay-${(i % 4) + 1}`}
            data-category={photo.category}
            data-tags={photo.tags.join("|")}
            data-index={i}
            data-src={photo.lightboxSrc}
            data-alt={photo.alt}
            data-aspect={photo.aspect}
            role="button"
            tabindex="0"
            aria-label={`Ver ${photo.title}`}
          >
            <div class="gallery__item-media">
              <div
                class="gallery__placeholder"
                style={`aspect-ratio: ${photo.aspect};`}
              >
                {photo.image ? (
                  <AstroImage
                    src={photo.image}
                    alt={photo.alt}
                    class="gallery__image"
                    loading="lazy"
                    format="webp"
                    quality={68}
                    sizes="(max-width: 540px) 95vw, (max-width: 900px) 48vw, 33vw"
                    widths={[520, 960, 1440]}
                  />
                ) : (
                  <img
                    src={photo.src}
                    alt={photo.alt}
                    class="gallery__image"
                    loading="lazy"
                    decoding="async"
                    width={photo.width}
                    height={photo.height}
                  />
                )}
              </div>
              <div class="gallery__overlay">
                <h3 class="gallery__overlay-title">{photo.title}</h3>
                <span class="gallery__overlay-cat">
                  {photo.displayCategory}
                </span>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ═══ LIGHTBOX ═══ -->
  <div
    class="lightbox"
    id="lightbox"
    aria-hidden="true"
    role="dialog"
    aria-label="Galería ampliada"
  >
    <button class="lightbox__close" aria-label="Cerrar galería">
      <svg
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>
    <button
      class="lightbox__arrow lightbox__arrow--prev"
      aria-label="Imagen anterior"
    >
      <svg
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path d="M15 18l-6-6 6-6"></path>
      </svg>
    </button>
    <button
      class="lightbox__arrow lightbox__arrow--next"
      aria-label="Imagen siguiente"
    >
      <svg
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path d="M9 18l6-6-6-6"></path>
      </svg>
    </button>
    <div class="lightbox__content">
      <img
        class="lightbox__placeholder is-ready"
        id="lightbox-image"
        src={photos[0]?.lightboxSrc ?? ""}
        alt="Imagen ampliada"
        loading="eager"
        decoding="async"
      />
      <div class="lightbox__info" id="lightbox-info">
        <h3 class="lightbox__title" id="lightbox-title"></h3>
        <span class="lightbox__cat label" id="lightbox-cat"></span>
        <span class="lightbox__counter" id="lightbox-counter"></span>
      </div>
    </div>
  </div>

  <!-- ═══ PANORAMA (Vista Global) ═══ -->
  <div
    class="panorama"
    id="panorama"
    aria-hidden="true"
    role="dialog"
    aria-label="Vista global de fotografías"
  >
    <div class="panorama__header">
      <span class="panorama__label label">Vista global</span>
      <button
        class="panorama__close"
        id="panorama-close"
        aria-label="Cerrar vista global"
      >
        <svg
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path d="M18 6L6 18M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <div class="panorama__scroll" id="panorama-scroll">
      <div class="panorama__canvas" id="panorama-canvas">
        {
          panoramaPhotos.map((photo, i) => (
            <div
              class={`pano-tile ${panoramaTileClasses[i]}`}
              data-pano-index={i}
              data-src={photo.lightboxSrc}
              data-alt={photo.alt}
              data-title={photo.title}
              data-cat={photo.displayCategory}
              data-aspect={photo.aspect}
              role="button"
              tabindex="0"
              aria-label={`Ver ${photo.title}`}
              style={`transition-delay: ${0.06 + i * 0.04}s`}
            >
              <div class="pano-tile__media">
                <div class="pano-tile__placeholder">
                  {photo.image ? (
                    <AstroImage
                      src={photo.image}
                      alt={photo.alt}
                      class="pano-tile__image"
                      loading="lazy"
                      format="webp"
                      quality={68}
                      sizes="(max-width: 768px) 45vw, 25vw"
                      widths={[420, 840, 1260]}
                    />
                  ) : (
                    <img
                      src={photo.src}
                      alt={photo.alt}
                      class="pano-tile__image"
                      loading="lazy"
                      decoding="async"
                      width={photo.width}
                      height={photo.height}
                    />
                  )}
                </div>
                <div class="pano-tile__overlay">
                  <h3 class="pano-tile__title">{photo.title}</h3>
                  <span class="pano-tile__cat">{photo.displayCategory}</span>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
    <div class="panorama__vignette"></div>
    <div class="panorama__edge panorama__edge--top"></div>
    <div class="panorama__edge panorama__edge--right"></div>
    <div class="panorama__edge panorama__edge--bottom"></div>
    <div class="panorama__edge panorama__edge--left"></div>
  </div>
</BaseLayout>

<script>
  const gradientStorageKey = "the-churfer-photo-hero-gradient";
  const gradientDefaults = {
    "--color-hero-1": "#0c1a2a",
    "--color-hero-2": "#0a1520",
    "--color-hero-3": "#043966",
    "--color-hero-4": "#0d1a25",
    "--hero-gradient-angle": "135deg",
    "--hero-stop-1": "0%",
    "--hero-stop-2": "30%",
    "--hero-stop-3": "60%",
    "--hero-stop-4": "100%",
  } as const;

  const root = document.documentElement;
  const gradientToggle = document.getElementById(
    "gradient-lab-toggle",
  ) as HTMLButtonElement | null;
  const gradientPanel = document.getElementById("gradient-lab-panel");
  const gradientReset = document.getElementById(
    "gradient-lab-reset",
  ) as HTMLButtonElement | null;
  const gradientCode = document.getElementById("gradient-css-output");
  const gradientControls = Array.from(
    document.querySelectorAll<HTMLInputElement>("[data-gradient-control]"),
  );
  const gradientValueNodes = Array.from(
    document.querySelectorAll<HTMLElement>("[data-gradient-value-for]"),
  );

  function readGradientValue(variable: string) {
    const inlineValue = root.style.getPropertyValue(variable).trim();
    if (inlineValue) return inlineValue;
    return getComputedStyle(root).getPropertyValue(variable).trim();
  }

  function setGradientPanelState(open: boolean) {
    if (!gradientToggle || !gradientPanel) return;
    gradientPanel.hidden = !open;
    gradientToggle.setAttribute("aria-expanded", String(open));
    gradientToggle.textContent = open
      ? "Ocultar degradado"
      : "Ajustar degradado";
  }

  function syncGradientCode() {
    if (!gradientCode) return;

    const values = Object.keys(gradientDefaults).map((key) => [
      key,
      readGradientValue(key),
    ]);

    gradientCode.textContent = `:root {
  --color-hero-1: ${values.find(([key]) => key === "--color-hero-1")?.[1]};
  --color-hero-2: ${values.find(([key]) => key === "--color-hero-2")?.[1]};
  --color-hero-3: ${values.find(([key]) => key === "--color-hero-3")?.[1]};
  --color-hero-4: ${values.find(([key]) => key === "--color-hero-4")?.[1]};
  --hero-gradient-angle: ${values.find(([key]) => key === "--hero-gradient-angle")?.[1]};
  --hero-stop-1: ${values.find(([key]) => key === "--hero-stop-1")?.[1]};
  --hero-stop-2: ${values.find(([key]) => key === "--hero-stop-2")?.[1]};
  --hero-stop-3: ${values.find(([key]) => key === "--hero-stop-3")?.[1]};
  --hero-stop-4: ${values.find(([key]) => key === "--hero-stop-4")?.[1]};
}`;
  }

  function syncGradientReadout(variable: string, value: string) {
    gradientValueNodes
      .filter((node) => node.dataset.gradientValueFor === variable)
      .forEach((node) => {
        node.textContent = value;
      });
  }

  function persistGradientSettings() {
    try {
      const payload = Object.fromEntries(
        Object.keys(gradientDefaults).map((key) => [
          key,
          readGradientValue(key),
        ]),
      );
      localStorage.setItem(gradientStorageKey, JSON.stringify(payload));
    } catch {
      // Ignore persistence failures in restricted environments.
    }
  }

  function applyGradientValue(
    variable: string,
    rawValue: string,
    unit = "",
    persist = true,
  ) {
    const nextValue = unit ? `${rawValue}${unit}` : rawValue;
    root.style.setProperty(variable, nextValue);
    syncGradientReadout(variable, nextValue);
    syncGradientCode();

    if (persist) {
      persistGradientSettings();
    }
  }

  function hydrateGradientControls() {
    let storedValues: Partial<Record<keyof typeof gradientDefaults, string>> =
      {};

    try {
      storedValues = JSON.parse(
        localStorage.getItem(gradientStorageKey) ?? "{}",
      ) as Partial<Record<keyof typeof gradientDefaults, string>>;
    } catch {
      storedValues = {};
    }

    gradientControls.forEach((control) => {
      const variable = control.dataset.var;
      if (!variable) return;

      const unit = control.dataset.unit ?? "";
      const fallbackValue =
        gradientDefaults[variable as keyof typeof gradientDefaults];
      const initialValue =
        storedValues[variable as keyof typeof gradientDefaults] ??
        fallbackValue;

      root.style.setProperty(variable, initialValue);

      if (unit) {
        control.value = initialValue.replace(unit, "");
      } else {
        control.value = initialValue;
      }

      syncGradientReadout(variable, initialValue);
    });

    syncGradientCode();
  }

  function resetGradientControls() {
    gradientControls.forEach((control) => {
      const variable = control.dataset.var;
      if (!variable) return;

      const unit = control.dataset.unit ?? "";
      const defaultValue =
        gradientDefaults[variable as keyof typeof gradientDefaults];

      root.style.setProperty(variable, defaultValue);
      control.value = unit ? defaultValue.replace(unit, "") : defaultValue;
      syncGradientReadout(variable, defaultValue);
    });

    try {
      localStorage.removeItem(gradientStorageKey);
    } catch {
      // Ignore storage failures.
    }

    syncGradientCode();
  }

  hydrateGradientControls();
  setGradientPanelState(false);

  gradientControls.forEach((control) => {
    control.addEventListener("input", () => {
      const variable = control.dataset.var;
      if (!variable) return;
      applyGradientValue(variable, control.value, control.dataset.unit ?? "");
    });
  });

  if (gradientToggle) {
    gradientToggle.onclick = () => {
      if (!gradientPanel) return;
      setGradientPanelState(gradientPanel.hidden === true);
    };
  }

  if (gradientReset) {
    gradientReset.onclick = resetGradientControls;
  }

  const grid = document.querySelector<HTMLElement>(".gallery__grid")!;
  const btns = document.querySelectorAll<HTMLButtonElement>(".filters__btn");
  const items = Array.from(
    document.querySelectorAll<HTMLElement>(".gallery__item"),
  );

  // ── Masonry: shortest column first ──
  function getColCount(): number {
    const w = grid.offsetWidth;
    if (w < 540) return 1;
    if (w < 900) return 2;
    return 3;
  }

  function layoutMasonry() {
    const cols = getColCount();
    const style = getComputedStyle(document.documentElement);
    const gap = parseFloat(style.getPropertyValue("--space-xs")) * 16 || 8;
    const gridWidth = grid.offsetWidth;
    const colWidth = (gridWidth - gap * (cols - 1)) / cols;
    const colHeights = new Array(cols).fill(0);

    // Visible items — lay out in shortest column
    const visible = items.filter((el) => !el.classList.contains("hidden"));
    visible.forEach((item) => {
      const shortest = colHeights.indexOf(Math.min(...colHeights));

      item.style.width = `${colWidth}px`;
      item.style.transform = `translate(${shortest * (colWidth + gap)}px, ${colHeights[shortest]}px)`;
      item.style.opacity = "1";

      colHeights[shortest] += item.offsetHeight + gap;
    });

    // Hidden items — fade out
    items
      .filter((el) => el.classList.contains("hidden"))
      .forEach((item) => {
        item.style.opacity = "0";
        item.style.pointerEvents = "none";
      });

    // Set container height
    grid.style.height = `${Math.max(...colHeights, 0)}px`;
  }

  // Initial layout (no transitions)
  layoutMasonry();
  requestAnimationFrame(() => grid.classList.add("masonry-ready"));

  // ── Filters ──
  btns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;
      btns.forEach((b) => b.setAttribute("aria-pressed", "false"));
      btn.setAttribute("aria-pressed", "true");

      items.forEach((item) => {
        const tags = (item.dataset.tags ?? "")
          .split("|")
          .map((tag) => tag.trim())
          .filter(Boolean);
        const match = filter === "all" || tags.includes(filter ?? "");
        item.classList.toggle("hidden", !match);
        item.style.pointerEvents = match ? "" : "none";
      });

      layoutMasonry();
    });
  });

  // ── Resize (debounced) ──
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(layoutMasonry, 100);
  });

  // ── Lightbox ──
  const lightbox = document.getElementById("lightbox")!;
  const lbTitle = document.getElementById("lightbox-title")!;
  const lbCat = document.getElementById("lightbox-cat")!;
  const lbCounter = document.getElementById("lightbox-counter")!;
  const lbImage = document.getElementById("lightbox-image") as HTMLImageElement;
  const closeBtn =
    lightbox.querySelector<HTMLButtonElement>(".lightbox__close")!;
  const prevBtn = lightbox.querySelector<HTMLButtonElement>(
    ".lightbox__arrow--prev",
  )!;
  const nextBtn = lightbox.querySelector<HTMLButtonElement>(
    ".lightbox__arrow--next",
  )!;

  let currentIndex = 0;
  let activeLightboxItems: HTMLElement[] = [];
  let lightboxImageToken = 0;

  function getVisibleItems(): HTMLElement[] {
    return items.filter((el) => !el.classList.contains("hidden"));
  }

  function getLightboxItems(): HTMLElement[] {
    return activeLightboxItems.length > 0
      ? activeLightboxItems
      : getVisibleItems();
  }

  function getLightboxText(item: HTMLElement, kind: "title" | "cat") {
    if (kind === "title") {
      return (
        item.dataset.title ??
        item.querySelector<HTMLElement>(".gallery__overlay-title")
          ?.textContent ??
        ""
      );
    }

    return (
      item.dataset.cat ??
      item.querySelector<HTMLElement>(".gallery__overlay-cat")?.textContent ??
      ""
    );
  }

  function swapLightboxImage(src: string, alt: string, aspect?: string) {
    return new Promise<void>((resolve) => {
      const currentSrc = lbImage.getAttribute("src") ?? "";
      if (currentSrc === src) {
        lbImage.alt = alt;
        if (aspect) lbImage.style.aspectRatio = aspect;
        lbImage.classList.add("is-ready");
        return resolve();
      }

      const token = ++lightboxImageToken;
      lbImage.classList.remove("is-ready");
      if (aspect) lbImage.style.aspectRatio = aspect;

      const preloaded = new window.Image();
      preloaded.decoding = "async";
      preloaded.src = src;

      const applyImage = () => {
        if (token !== lightboxImageToken) return resolve();
        lbImage.src = src;
        lbImage.alt = alt;
        requestAnimationFrame(() => {
          lbImage.classList.add("is-ready");
          resolve();
        });
      };

      preloaded.addEventListener("load", applyImage, { once: true });
      preloaded.addEventListener("error", applyImage, { once: true });
    });
  }

  async function showImage(index: number) {
    const sourceItems = getLightboxItems();
    if (sourceItems.length === 0) return;
    currentIndex =
      ((index % sourceItems.length) + sourceItems.length) % sourceItems.length;
    const item = sourceItems[currentIndex];

    lbTitle.textContent = getLightboxText(item, "title");
    lbCat.textContent = getLightboxText(item, "cat");
    lbCounter.textContent = `${currentIndex + 1} / ${sourceItems.length}`;

    await swapLightboxImage(
      item.dataset.src ?? "",
      item.dataset.alt ?? "Imagen ampliada",
      item.dataset.aspect,
    );
  }

  async function openLightbox(index: number, sourceItems = getVisibleItems()) {
    activeLightboxItems = sourceItems;
    lightbox.setAttribute("aria-hidden", "false");
    syncScrollLock();
    lbImage.classList.remove("is-ready");
    lbImage.removeAttribute("src");
    await showImage(index);
    if (lightbox.getAttribute("aria-hidden") === "true") return;
    closeBtn.focus();
  }

  function closeLightbox() {
    lightboxImageToken += 1;
    activeLightboxItems = [];
    lightbox.setAttribute("aria-hidden", "true");
    syncScrollLock();
  }

  items.forEach((item) => {
    const handler = () => {
      const visible = getVisibleItems();
      const idx = visible.indexOf(item);
      if (idx !== -1) void openLightbox(idx, visible);
    };
    item.addEventListener("click", handler);
    item.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        handler();
      }
    });
  });

  const galleryImages =
    document.querySelectorAll<HTMLImageElement>(".gallery__image");
  galleryImages.forEach((img) => {
    if (!img.complete) {
      img.addEventListener("load", layoutMasonry, { once: true });
    }
  });

  prevBtn.addEventListener("click", () => void showImage(currentIndex - 1));
  nextBtn.addEventListener("click", () => void showImage(currentIndex + 1));
  closeBtn.addEventListener("click", closeLightbox);

  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  // ── Panorama (Vista Global) ──
  const panorama = document.getElementById("panorama")!;
  const panoScroll = document.getElementById("panorama-scroll")!;
  const panoCanvas = document.getElementById("panorama-canvas")!;
  const panoOpen = document.getElementById("panorama-open")!;
  const panoCl = document.getElementById("panorama-close")!;
  const panoTiles = Array.from(
    document.querySelectorAll<HTMLElement>(".pano-tile"),
  );
  const panoEdges = {
    top: panorama.querySelector<HTMLElement>(".panorama__edge--top")!,
    right: panorama.querySelector<HTMLElement>(".panorama__edge--right")!,
    bottom: panorama.querySelector<HTMLElement>(".panorama__edge--bottom")!,
    left: panorama.querySelector<HTMLElement>(".panorama__edge--left")!,
  };

  const EDGE_ZONE = 100;
  const MAX_SPEED = 14;
  let panoRAF: number | null = null;
  let panoMouseX = window.innerWidth / 2;
  let panoMouseY = window.innerHeight / 2;

  function syncScrollLock() {
    document.body.style.overflow =
      lightbox.getAttribute("aria-hidden") !== "true" ||
      panorama.getAttribute("aria-hidden") !== "true"
        ? "hidden"
        : "";
  }

  function openPanorama() {
    panorama.setAttribute("aria-hidden", "false");
    syncScrollLock();
    requestAnimationFrame(() => {
      panoScroll.scrollLeft =
        (panoCanvas.scrollWidth - panoScroll.clientWidth) / 2;
      panoScroll.scrollTop =
        (panoCanvas.scrollHeight - panoScroll.clientHeight) / 2;
      startEdgeScroll();
    });
  }

  function closePanorama() {
    stopEdgeScroll();
    panorama.setAttribute("aria-hidden", "true");
    syncScrollLock();
  }

  function startEdgeScroll() {
    function tick() {
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      let vx = 0,
        vy = 0;

      if (panoMouseX < EDGE_ZONE) {
        vx = -MAX_SPEED * Math.pow(1 - panoMouseX / EDGE_ZONE, 1.5);
      } else if (panoMouseX > vw - EDGE_ZONE) {
        vx = MAX_SPEED * Math.pow(1 - (vw - panoMouseX) / EDGE_ZONE, 1.5);
      }

      if (panoMouseY < EDGE_ZONE) {
        vy = -MAX_SPEED * Math.pow(1 - panoMouseY / EDGE_ZONE, 1.5);
      } else if (panoMouseY > vh - EDGE_ZONE) {
        vy = MAX_SPEED * Math.pow(1 - (vh - panoMouseY) / EDGE_ZONE, 1.5);
      }

      if (vx !== 0 || vy !== 0) {
        panoScroll.scrollLeft += vx;
        panoScroll.scrollTop += vy;
      }

      const canLeft = panoScroll.scrollLeft > 0;
      const canRight =
        panoScroll.scrollLeft <
        panoScroll.scrollWidth - panoScroll.clientWidth - 1;
      const canTop = panoScroll.scrollTop > 0;
      const canBottom =
        panoScroll.scrollTop <
        panoScroll.scrollHeight - panoScroll.clientHeight - 1;

      panoEdges.left.classList.toggle(
        "is-active",
        panoMouseX < EDGE_ZONE && canLeft,
      );
      panoEdges.right.classList.toggle(
        "is-active",
        panoMouseX > vw - EDGE_ZONE && canRight,
      );
      panoEdges.top.classList.toggle(
        "is-active",
        panoMouseY < EDGE_ZONE && canTop,
      );
      panoEdges.bottom.classList.toggle(
        "is-active",
        panoMouseY > vh - EDGE_ZONE && canBottom,
      );

      panoRAF = requestAnimationFrame(tick);
    }
    panoRAF = requestAnimationFrame(tick);
  }

  function stopEdgeScroll() {
    if (panoRAF !== null) {
      cancelAnimationFrame(panoRAF);
      panoRAF = null;
    }
    Object.values(panoEdges).forEach((el) => el.classList.remove("is-active"));
  }

  panorama.addEventListener("mousemove", (e) => {
    panoMouseX = e.clientX;
    panoMouseY = e.clientY;
  });

  panoTiles.forEach((tile, index) => {
    const handler = () => {
      void openLightbox(index, panoTiles);
    };

    tile.addEventListener("click", handler);
    tile.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        handler();
      }
    });
  });

  panoOpen.addEventListener("click", openPanorama);
  panoCl.addEventListener("click", closePanorama);

  // ── Keyboard (unified) ──
  document.addEventListener("keydown", (e) => {
    if (
      lightbox.getAttribute("aria-hidden") === "true" &&
      panorama.getAttribute("aria-hidden") === "true"
    ) {
      return;
    }

    if (lightbox.getAttribute("aria-hidden") !== "true") {
      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowLeft") void showImage(currentIndex - 1);
      if (e.key === "ArrowRight") void showImage(currentIndex + 1);
      return;
    }
    if (panorama.getAttribute("aria-hidden") !== "true") {
      if (e.key === "Escape") closePanorama();
    }
  });
</script>

